<%- include('partials/header') %>

<!-- Emergency Alarm Siren Sound (Audio element using Web Audio API or oscillator if blocked, but inline audio works) -->
<audio id="sirenSound" loop src="https://actions.google.com/sounds/v1/alarms/digital_watch_alarm_long.ogg"></audio>

<div class="container" style="margin-top: 20px; margin-bottom: 50px;">
    <!-- Guard Header with Online Status -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default" style="border-left: 5px solid #4caf50 !important;">
                <div class="panel-body">
                    <div class="row">
                        <div class="col-sm-8">
                            <h3 style="margin-top: 5px; color: #4caf50;"><i class="fas fa-shield-alt"></i> Security Guard Gate Portal</h3>
                            <p class="text-muted" style="margin-bottom: 0;">Active Gate: <strong>Main Gate 1</strong> | Guard: <strong><%= user.firstName %> <%= user.lastName %></strong></p>
                        </div>
                        <div class="col-sm-4 text-right">
                            <span class="label label-success" style="font-size: 14px;"><i class="fas fa-circle"></i> GATE STATUS: ONLINE</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SOS Button Row -->
    <div class="row" style="margin-bottom: 25px;">
        <div class="col-md-12">
            <div class="panel panel-danger" style="background: rgba(233, 30, 99, 0.1) !important; border: 1px dashed crimson !important;">
                <div class="panel-body text-center">
                    <h4 style="color: #e91e63; font-weight: bold;"><i class="fas fa-exclamation-triangle"></i> EMERGENCY SOS PANIC TRIGGER</h4>
                    <p class="text-muted">Click this button to trigger a society-wide emergency alert and notify all residents.</p>
                    <button class="btn btn-danger btn-lg pulse-sos" onclick="triggerSOS()" id="sosBtn" style="padding: 15px 40px; font-size: 16px; border-radius: 50px !important;">
                        <i class="fas fa-bell"></i> TRIGGER SOS ALERT
                    </button>
                    <button class="btn btn-default btn-md" onclick="stopSOS()" id="stopSosBtn" style="display:none; margin-left: 10px;">
                        <i class="fas fa-volume-mute"></i> Stop Alarm
                    </button>
                    <div id="sosAlertStatus" style="margin-top: 10px; font-weight: bold; color: #e91e63; display: none;">
                        ⚠️ SOCIETY SOS ALARM ACTIVE! Broadcasting to all towers...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Menu -->
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-bars"></i> Gate Actions</h4></div>
                <div class="panel-body" style="padding: 10px !important;">
                    <ul class="nav nav-pills nav-stacked" id="guardTabs">
                        <li class="active"><a href="#qrScanTab" data-toggle="pill"><i class="fas fa-qrcode"></i> Scan Visitor QR Pass</a></li>
                        <li><a href="#visitorLogTab" data-toggle="pill"><i class="fas fa-user-plus"></i> Manual Visitor Entry</a></li>
                        <li><a href="#activeVisitorsTab" data-toggle="pill"><i class="fas fa-users-cog"></i> Active Visitors (<%= activeVisitors.length %>)</a></li>
                        <li><a href="#parcelTab" data-toggle="pill"><i class="fas fa-box-open"></i> Parcel Log Manager</a></li>
                        <li><a href="#vehicleTab" data-toggle="pill"><i class="fas fa-car"></i> Vehicle Log & Parking</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-phone-alt"></i> Intercom Speed Dial</h4></div>
                <div class="panel-body">
                    <ul class="list-group" style="width: 100%; margin-bottom: 0;">
                        <li class="list-group-item" style="display: flex; justify-content: space-between; align-items: center;">
                            <span>Ambulance</span>
                            <a href="tel:102" class="btn btn-success btn-xs"><i class="fas fa-phone"></i> Dial</a>
                        </li>
                        <li class="list-group-item" style="display: flex; justify-content: space-between; align-items: center;">
                            <span>Police Station</span>
                            <a href="tel:100" class="btn btn-success btn-xs"><i class="fas fa-phone"></i> Dial</a>
                        </li>
                        <li class="list-group-item" style="display: flex; justify-content: space-between; align-items: center;">
                            <span>Society Admin</span>
                            <a href="tel:999998888" class="btn btn-info btn-xs"><i class="fas fa-phone"></i> Call</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Tab contents -->
        <div class="col-md-9">
            <div class="tab-content">

                <!-- Visitor QR Pass Code Scanner Tab -->
                <div class="tab-pane active" id="qrScanTab">
                    <div class="panel panel-default">
                        <div class="panel-heading"><h4><i class="fas fa-qrcode"></i> Verify Visitor Pre-Approved QR Code</h4></div>
                        <div class="panel-body text-center">
                            <p class="text-muted">Enter or scan the Guest QR Pass Code (e.g. <code>GUEST123</code> or <code>DELIV456</code>) generated by residents.</p>
                            
                            <!-- Virtual CCTV Camera feed scanner mockup -->
                            <div class="cctv-stream-container center" style="width: 100%; max-width: 400px; height: 250px; background: #111; margin-bottom: 20px; border: 2px solid var(--border-glass);">
                                <div style="position: absolute; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff;">
                                    <i class="fas fa-expand" style="font-size: 5rem; color: #00bcd4; opacity: 0.5; animation: pulse-cctv 1.5s infinite;"></i>
                                    <div style="background: rgba(0,0,0,0.6); padding: 5px 15px; border-radius: 20px; margin-top: 15px; font-size: 12px;">
                                        SCANNER CAMERA 1 ACTIVE
                                    </div>
                                </div>
                            </div>
                            
                            <form action="/guard/visitor/verify-qr" method="POST" class="form-inline">
                                <div class="form-group" style="margin-right: 10px;">
                                    <input type="text" name="qrPassCode" class="form-control text-center" placeholder="ENTER QR CODE" style="font-weight: bold; font-size: 16px; width: 250px;" required>
                                </div>
                                <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Validate Pass</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Manual Visitor Entry Form Tab -->
                <div class="tab-pane" id="visitorLogTab">
                    <div class="panel panel-default">
                        <div class="panel-heading"><h4><i class="fas fa-user-plus"></i> Manual Visitor Log Entry</h4></div>
                        <div class="panel-body">
                            <form action="/guard/visitor/manual-entry" method="POST" id="visitorForm">
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Visitor Name:</label>
                                            <input type="text" name="name" class="form-control" placeholder="Full Name" required>
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Phone Number:</label>
                                            <input type="text" name="phone" class="form-control" placeholder="10-digit Mobile Number" required>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Flat Number Target:</label>
                                            <input type="text" name="flatNumber" class="form-control" placeholder="e.g. A-402" required>
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Visitor Type:</label>
                                            <select name="type" class="form-control" onchange="toggleCompany(this)">
                                                <option value="guest">Guest / Friend</option>
                                                <option value="delivery">Delivery Agent</option>
                                                <option value="cab">Cab Driver</option>
                                                <option value="other">Other Service</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-4" id="companyField" style="display: none;">
                                        <div class="form-group">
                                            <label>Company/Service:</label>
                                            <input type="text" name="company" class="form-control" placeholder="Zomato, Swiggy, Amazon etc">
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="form-group">
                                            <label>Vehicle Plate Number (Optional):</label>
                                            <input type="text" name="vehicleNumber" class="form-control" placeholder="e.g. MH-12-AB-1234">
                                        </div>
                                    </div>
                                    <div class="col-sm-6 text-center">
                                        <label>Visitor Photo Capture:</label>
                                        <div style="border: 1px dashed var(--border-glass); border-radius: 8px; padding: 10px; display: flex; align-items: center; justify-content: center; height: 50px;">
                                            <button type="button" class="btn btn-info btn-xs" onclick="simulatePhotoCapture()"><i class="fas fa-camera"></i> Capture Photo</button>
                                            <span id="photoCapturedText" class="text-success" style="margin-left: 10px; font-weight: bold; display: none;">✅ Photo Captured!</span>
                                            <input type="hidden" name="photoCaptured" id="photoCapturedVal" value="false">
                                        </div>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-success"><i class="fas fa-sign-in-alt"></i> Grant Entry Pass</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Active Checked-In Visitors Tab -->
                <div class="tab-pane" id="activeVisitorsTab">
                    <div class="panel panel-default">
                        <div class="panel-heading"><h4><i class="fas fa-users-cog"></i> Active Checked-In Visitors</h4></div>
                        <div class="panel-body">
                            <% if (activeVisitors.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover">
                                        <thead>
                                            <tr>
                                                <th>Photo</th>
                                                <th>Name</th>
                                                <th>Phone</th>
                                                <th>Flat</th>
                                                <th>Entry Time</th>
                                                <th>Type</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% activeVisitors.forEach(function(vis) { %>
                                                <tr>
                                                    <td>
                                                        <img src="<%= vis.photoUrl %>" alt="<%= vis.name %>" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border-glass);">
                                                    </td>
                                                    <td><strong><%= vis.name %></strong></td>
                                                    <td><%= vis.phone %></td>
                                                    <td><span class="label label-danger"><%= vis.flatNumber %></span></td>
                                                    <td><%= new Date(vis.entryTime).toLocaleTimeString() %></td>
                                                    <td>
                                                        <span class="label label-info"><%= vis.type.toUpperCase() %> <%= vis.company ? '(' + vis.company + ')' : '' %></span>
                                                    </td>
                                                    <td>
                                                        <form action="/guard/visitor/checkout" method="POST">
                                                            <input type="hidden" name="visitorId" value="<%= vis._id %>">
                                                            <button type="submit" class="btn btn-warning btn-xs"><i class="fas fa-sign-out-alt"></i> Check Out</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <p class="text-muted text-center" style="padding: 20px;">No active visitors checked-in currently.</p>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Parcel Manager Tab -->
                <div class="tab-pane" id="parcelTab">
                    <div class="panel panel-default">
                        <div class="panel-heading"><h4><i class="fas fa-box-open"></i> Package & Courier Gate Logger</h4></div>
                        <div class="panel-body">
                            <form action="/guard/parcel/add" method="POST" style="margin-bottom: 25px;">
                                <div class="row">
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Target Flat:</label>
                                            <input type="text" name="flatNumber" class="form-control" placeholder="e.g. B-102" required>
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Courier Service:</label>
                                            <input type="text" name="company" class="form-control" placeholder="Amazon, Flipkart, etc." required>
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>Recipient Name:</label>
                                            <input type="text" name="recipientName" class="form-control" placeholder="Owner/Tenant Name">
                                        </div>
                                    </div>
                                    <div class="col-sm-3">
                                        <div class="form-group">
                                            <label>&nbsp;</label>
                                            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-plus"></i> Log Parcel</button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            <hr style="border-color: var(--border-glass);">
                            <h4>Awaiting Collection at Gate Desk</h4>
                            <% if (uncollectedParcels && uncollectedParcels.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>Date Logged</th>
                                                <th>Flat</th>
                                                <th>Courier Company</th>
                                                <th>Recipient Name</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% uncollectedParcels.forEach(function(par) { %>
                                                <tr>
                                                    <td><%= new Date(par.entryTime).toLocaleString().split(', ')[0] %></td>
                                                    <td><span class="label label-danger"><%= par.flatNumber %></span></td>
                                                    <td><%= par.company %></td>
                                                    <td><%= par.name || 'Resident' %></td>
                                                    <td>
                                                        <form action="/guard/parcel/collect" method="POST">
                                                            <input type="hidden" name="visitorId" value="<%= par._id %>">
                                                            <button type="submit" class="btn btn-success btn-xs"><i class="fas fa-handshake"></i> Collected / Delivered</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <p class="text-muted text-center" style="padding: 20px;">No parcels waiting at gate desk.</p>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Vehicle Registry & Parking Violations Tab -->
                <div class="tab-pane" id="vehicleTab">
                    <div class="panel panel-default">
                        <div class="panel-heading"><h4><i class="fas fa-car"></i> Gate Vehicle Log & Parking Search</h4></div>
                        <div class="panel-body">
                            <!-- Look up flat parking allotment -->
                            <h4>Verify Resident Parking Spot</h4>
                            <form id="parkingSearchForm" class="form-inline" style="margin-bottom: 20px;">
                                <div class="form-group" style="margin-right: 10px;">
                                    <input type="text" id="searchFlatNo" class="form-control" placeholder="Enter Flat Number" required>
                                </div>
                                <button type="button" class="btn btn-info" onclick="searchParkingSlot()"><i class="fas fa-search"></i> Check Allotment</button>
                            </form>
                            <div id="parkingSearchResult" style="padding: 10px; background: rgba(0,188,212,0.1); border-radius: 8px; margin-bottom: 25px; display: none;"></div>

                            <!-- Log Parking Violation -->
                            <hr style="border-color: var(--border-glass);">
                            <h4>Report Parking Violation</h4>
                            <form action="/guard/vehicle/violation" method="POST">
                                <div class="row">
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Vehicle Plate Number:</label>
                                            <input type="text" name="plateNumber" class="form-control" placeholder="e.g. MH-12-XY-9999" required>
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Flat Owner (if known):</label>
                                            <input type="text" name="flatNumber" class="form-control" placeholder="e.g. C-701">
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <div class="form-group">
                                            <label>Violation Type:</label>
                                            <select name="violation" class="form-control">
                                                <option value="Parked in wrong slot">Parked in wrong slot</option>
                                                <option value="Blocking access road">Blocking access road</option>
                                                <option value="No society entry sticker">No society entry sticker</option>
                                                <option value="Double parking">Double parking</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-danger"><i class="fas fa-exclamation-triangle"></i> Log Parking Penalty</button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    function toggleCompany(select) {
        const companyField = document.getElementById('companyField');
        if (select.value === 'delivery' || select.value === 'cab' || select.value === 'other') {
            companyField.style.display = 'block';
        } else {
            companyField.style.display = 'none';
        }
    }

    function simulatePhotoCapture() {
        document.getElementById('photoCapturedText').style.display = 'inline';
        document.getElementById('photoCapturedVal').value = 'true';
    }

    function triggerSOS() {
        const audio = document.getElementById('sirenSound');
        audio.play().catch(e => console.log('Audio auto-play blocked, playing visual pulse only'));
        
        document.getElementById('sosAlertStatus').style.display = 'block';
        document.getElementById('stopSosBtn').style.display = 'inline-block';
        
        // Post alert trigger to server
        $.post('/guard/sos/trigger', {}, function(data) {
            console.log('SOS alert broadcasted.');
        });
    }

    function stopSOS() {
        const audio = document.getElementById('sirenSound');
        audio.pause();
        audio.currentTime = 0;
        document.getElementById('sosAlertStatus').style.display = 'none';
        document.getElementById('stopSosBtn').style.display = 'none';
    }

    function searchParkingSlot() {
        const flatNo = document.getElementById('searchFlatNo').value;
        $.get('/guard/parking/allotment?flatNumber=' + flatNo, function(data) {
            const resultBox = document.getElementById('parkingSearchResult');
            resultBox.style.display = 'block';
            if (data.success) {
                resultBox.innerHTML = `<strong>Flat:</strong> ${data.flatNumber} | <strong>Owner:</strong> ${data.ownerName} | <strong>Allotted Slot:</strong> <span class="label label-warning">${data.parkingSlot}</span> | <strong>Sticker ID:</strong> ${data.stickerNumber}`;
            } else {
                resultBox.innerHTML = `❌ Flat ${flatNo} has no vehicle or parking spot registered.`;
            }
        });
    }
</script>

<style>
    @keyframes pulse-cctv {
        0% { transform: scale(0.9); opacity: 0.4; }
        50% { transform: scale(1.05); opacity: 0.8; }
        100% { transform: scale(0.9); opacity: 0.4; }
    }
</style>

<%- include('partials/footer') %>
