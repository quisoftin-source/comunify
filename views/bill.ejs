<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <!-- Title -->
    <div class="row">
        <div class="col-sm-8">
            <h2 style="color: #4caf50; margin-top: 5px;"><i class="fas fa-file-invoice-dollar"></i> Maintenance Billing Desk</h2>
            <p class="text-muted">Review current dues, view smart utility meter readings, and download official e-receipts.</p>
        </div>
        <div class="col-sm-4 text-right">
            <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <a href="/editBill" class="btn btn-primary" style="margin-top: 5px;">
                    <i class="fas fa-edit"></i> Configure Pricing
                </a>
            <% } %>
        </div>
    </div>
    
    <hr style="border-color: var(--border-glass);">

    <div class="row">
        <!-- Invoice View -->
        <div class="col-md-7">
            <div class="panel panel-default">
                <div class="panel-heading" style="display: flex; justify-content: space-between; align-items: center;">
                    <h4><i class="fas fa-receipt"></i> Monthly Maintenance Statement</h4>
                    <div>
                        <button id="download-btn" class="btn btn-info btn-xs" onclick="printBill()"><i class="fas fa-download"></i> PDF Bill</button>
                    </div>
                </div>
                <div class="panel-body" id="print-content" style="background: rgba(20,22,32,0.6); color: #fff;">
                    <div style="border-bottom: 1px solid var(--border-glass); padding-bottom: 15px; margin-bottom: 20px; display: flex; justify-content: space-between;">
                        <div>
                            <h3 style="margin: 0; font-weight: bold; color: var(--accent-cyan);"><%= society.societyName %></h3>
                            <p style="margin: 5px 0 0 0; font-size:12px; color: var(--text-secondary);">
                                <%= society.societyAddress.address %>, <%= society.societyAddress.city %>, <%= society.societyAddress.postalCode %>
                            </p>
                        </div>
                        <div class="text-right">
                            <h4 style="margin: 0; font-weight: bold;">INVOICE</h4>
                            <p style="margin: 5px 0 0 0; font-size: 11px; color: var(--text-secondary);">
                                Bill No: <strong>#ES-<%= new Date().getMonth() + 1 %><%= new Date().getFullYear() %></strong><br>
                                Billing Month: <strong><%= monthName %>, <%= year %></strong>
                            </p>
                        </div>
                    </div>

                    <div style="margin-bottom: 20px; display: flex; justify-content: space-between; font-size: 13px;">
                        <div>
                            <span style="color: var(--text-secondary);">BILL TO:</span><br>
                            <strong><%= resident.firstName %> <%= resident.lastName %></strong><br>
                            Flat Number: <strong><%= resident.flatNumber %></strong>
                        </div>
                        <div class="text-right">
                            <span style="color: var(--text-secondary);">INVOICE DATE:</span><br>
                            <strong><%= date %></strong>
                        </div>
                    </div>

                    <table class="table" style="color: #fff !important; font-size: 13px;">
                        <thead>
                            <tr style="background: rgba(255,255,255,0.02);">
                                <th>#</th>
                                <th>Particulars / Charge Type</th>
                                <th>Month</th>
                                <th class="text-right">Attachment</th>
                                <th class="text-right">Amount Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (locals.activeBills && activeBills.length > 0) { %>
                                <% activeBills.forEach(function(bill, index) { %>
                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td><%= bill.title %></td>
                                        <td><%= bill.month %> <%= bill.year %></td>
                                        <td class="text-right">
                                            <% if (bill.attachmentPath) { %>
                                                <a href="<%= bill.attachmentPath %>" target="_blank" class="btn btn-danger btn-xs"><i class="fas fa-file-pdf"></i> View Attachment</a>
                                            <% } else { %>
                                                <span class="text-muted" style="font-size: 11px;">No attachment</span>
                                            <% } %>
                                        </td>
                                        <td class="text-right"><%= formatINR(bill.amount) %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td>1</td>
                                    <td>Society Common Maintenance Charges</td>
                                    <td><%= monthName %> <%= year %></td>
                                    <td class="text-right"><span class="text-muted" style="font-size: 11px;">N/A</span></td>
                                    <td class="text-right"><%= formatINR(society.maintenanceBill.societyCharges) %></td>
                                </tr>
                                <tr>
                                    <td>2</td>
                                    <td>Repairs and Sinking Fund Contribution</td>
                                    <td><%= monthName %> <%= year %></td>
                                    <td class="text-right"><span class="text-muted" style="font-size: 11px;">N/A</span></td>
                                    <td class="text-right"><%= formatINR(society.maintenanceBill.sinkingFund) %></td>
                                </tr>
                                <tr>
                                    <td>3</td>
                                    <td>Smart Water Meter Reading (Water Charges)</td>
                                    <td><%= monthName %> <%= year %></td>
                                    <td class="text-right"><span class="text-muted" style="font-size: 11px;">N/A</span></td>
                                    <td class="text-right"><%= formatINR(society.maintenanceBill.waterCharges) %></td>
                                </tr>
                                <tr>
                                    <td>4</td>
                                    <td>Smart Electricity Meter Reading (Common Power)</td>
                                    <td><%= monthName %> <%= year %></td>
                                    <td class="text-right"><span class="text-muted" style="font-size: 11px;">N/A</span></td>
                                    <td class="text-right"><%= formatINR(society.maintenanceBill.repairsAndMaintenance) %></td>
                                </tr>
                                <tr>
                                    <td>5</td>
                                    <td>Assigned Vehicle Parking Charges</td>
                                    <td><%= monthName %> <%= year %></td>
                                    <td class="text-right"><span class="text-muted" style="font-size: 11px;">N/A</span></td>
                                    <td class="text-right"><%= formatINR(society.maintenanceBill.parkingCharges) %></td>
                                </tr>
                            <% } %>
                            
                            <tr style="background: rgba(0, 188, 212, 0.05); font-weight: bold; font-size: 15px;">
                                <td></td>
                                <td>Total Outstanding Dues</td>
                                <td></td>
                                <td></td>
                                <td class="text-right" style="color: var(--accent-cyan);"><%= formatINR(totalAmount) %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="panel-footer" style="display: flex; justify-content: flex-end; gap: 10px;">
                    <!-- Real Stripe checkout button -->
                    <button id="checkout-button" class="btn btn-primary btn-sm" <% if(totalAmount==0){ %> disabled <% } %>><i class="fab fa-stripe"></i> Stripe Checkout</button>
                    <!-- Simulated local checkout button for visual test -->
                    <form action="/bill/simulate-payment" method="POST" style="display:inline;">
                        <input type="hidden" name="amount" value="<%= totalAmount %>">
                        <button type="submit" class="btn btn-success btn-sm" <% if(totalAmount==0){ %> disabled <% } %>><i class="fas fa-shield-alt"></i> Instant Payment Simulator</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Receipt History Sidebar -->
        <div class="col-md-5">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-history"></i> Latest Paid E-Receipt</h4></div>
                <div class="panel-body">
                    <% if (receipt && receipt.invoice) { %>
                        <div id="receipt-print-content" style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; background: rgba(0,200,83,0.05); margin-bottom: 15px;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size:12px;">
                                <span class="text-success" style="font-weight: bold;"><i class="fas fa-check-circle"></i> TRANSACTION SUCCESSFUL</span>
                                <small class="text-muted">Receipt ID: <%= receipt.invoice %></small>
                            </div>
                            <h4 style="margin-top: 5px; font-weight: bold; color: #fff;">E-Receipt</h4>
                            <p style="font-size: 13px; line-height: 1.5; color: var(--text-secondary);">
                                Received with thanks from <strong><%= resident.firstName %> <%= resident.lastName %></strong> (Flat <%= resident.flatNumber %>) the sum of <strong><%= formatINR(receipt.amount) %></strong> on <%= new Date(receipt.date).toLocaleDateString() %>.
                            </p>
                            <hr style="border-color: var(--border-glass); margin: 10px 0;">
                            <p class="text-muted" style="font-size: 11px; margin-bottom: 0;">
                                Account dues have been credited. Receipts can be generated as PDF.
                            </p>
                        </div>
                        <button class="btn btn-info btn-block btn-sm" onclick="printReceipt()"><i class="fas fa-print"></i> Print Receipt</button>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 20px;">No transaction receipts logged. Complete a payment to generate receipts.</p>
                    <% } %>
                </div>
            </div>

            <!-- Smart Meter Readings Widget -->
            <div class="panel panel-default" style="border-left: 4px solid var(--accent-cyan) !important;">
                <div class="panel-heading"><h4><i class="fas fa-tachometer-alt"></i> Smart Meter Integration</h4></div>
                <div class="panel-body" style="font-size: 12px; line-height: 1.6;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>💧 Smart Water Meter ID:</span>
                        <strong>W-MET-<%= resident.flatNumber %></strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>Current Water Usage:</span>
                        <strong class="text-info">240 Liters (<%= formatINR(society.maintenanceBill.waterCharges) %>)</strong>
                    </div>
                    <hr style="border-color: var(--border-glass); margin: 8px 0;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>⚡ Smart Electricity Meter ID:</span>
                        <strong>E-MET-<%= resident.flatNumber %></strong>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span>Current Power Consumption:</span>
                        <strong class="text-info">180 kWh (<%= formatINR(society.maintenanceBill.repairsAndMaintenance) %>)</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Accounting Ledger for Society Admin -->
    <% if (resident.isAdmin) { %>
        <div class="row" style="margin-top: 20px;">
            <div class="col-md-12">
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-book"></i> Society Defaulters Ledger (Accounting)</h4></div>
                    <div class="panel-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle" style="font-size: 13px;">
                                <thead>
                                    <tr>
                                        <th>Resident Name</th>
                                        <th>Flat No</th>
                                        <th>Outstanding Dues</th>
                                        <th>Payment Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% societyResidents.forEach(function(res) { %>
                                        <% 
                                            // Compute dues for this member
                                            let resDues = res.makePayment || 0;
                                        %>
                                        <tr>
                                            <td><strong><%= res.firstName %> <%= res.lastName %></strong></td>
                                            <td><span class="label label-danger">Flat <%= res.flatNumber %></span></td>
                                            <td><strong><%= formatINR(resDues) %></strong></td>
                                            <td>
                                                <span class="label <%= resDues === 0 ? 'label-success' : 'label-danger' %>">
                                                    <%= resDues === 0 ? 'PAID' : 'UNPAID DUES' %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>

<script>
    // Integration of PDF printing using html2pdf
    function printBill() {
        const element = document.getElementById('print-content');
        const opt = {
            margin:       1,
            filename:     'Maintenance_Bill_Flat_<%= resident.flatNumber %>.pdf',
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2, backgroundColor: '#12141c' },
            jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
        };
        html2pdf().set(opt).from(element).save();
    }

    function printReceipt() {
        const element = document.getElementById('receipt-print-content');
        const opt = {
            margin:       1,
            filename:     'E_Receipt_Flat_<%= resident.flatNumber %>.pdf',
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2, backgroundColor: '#12141c' },
            jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
        };
        html2pdf().set(opt).from(element).save();
    }
</script>

<script type="text/javascript">
    // Stripe publishable key configuration
    var stripe = Stripe("pk_test_51ISbSbKm0w4ydVKOdI0dJjnDP1wkND8lSBs02U2bXTT0QX3kRDmLzO38Q6I4SmlsFP3mAaXLAdaFKPhIz2o0axjk00FkI15wzR");
    var checkoutButton = document.getElementById("checkout-button");

    if (checkoutButton) {
        checkoutButton.addEventListener("click", function () {
            fetch("/checkout-session", {
                method: "POST",
            })
            .then(function (response) {
                return response.json();
            })
            .then(function (session) {
                return stripe.redirectToCheckout({ sessionId: session.id });
            })
            .then(function (result) {
                if (result.error) {
                    alert(result.error.message);
                }
            })
            .catch(function (error) {
                console.error("Error:", error);
            });
        });
    }
</script>

<%- include('partials/footer') %>