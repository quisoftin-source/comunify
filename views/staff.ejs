<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="row">
        <div class="col-md-12">
            <h2 style="color: #4caf50;"><i class="fas fa-users-cog"></i> Society Staff Management</h2>
            <p class="text-muted">Monitor society guards, electricians, plumbers, housekeepers, and track their attendance.</p>
            <hr style="border-color: var(--border-glass);">
        </div>
    </div>

    <div class="row">
        <!-- Staff Directory -->
        <div class="col-md-8">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-address-book"></i> Active Staff Directory</h4></div>
                <div class="panel-body">
                    <% if (staff && staff.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Staff Name</th>
                                        <th>Department Role</th>
                                        <th>Contact Number</th>
                                        <th>Rating</th>
                                        <th>Attendance Today</th>
                                        <% if (user.role === 'society_admin') { %>
                                            <th>Actions</th>
                                        <% } %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% staff.forEach(function(member) { %>
                                        <tr>
                                            <td><strong><%= member.name %></strong></td>
                                            <td>
                                                <span class="label label-info"><%= member.role.toUpperCase() %></span>
                                            </td>
                                            <td><%= member.phoneNumber %></td>
                                            <td style="color: #ff9800;">
                                                <% for(let i = 0; i < 5; i++) { %>
                                                    <i class="<%= i < Math.floor(member.rating) ? 'fas' : 'far' %> fa-star"></i>
                                                <% } %>
                                                <small class="text-muted">(<%= member.rating.toFixed(1) %>)</small>
                                            </td>
                                            <td>
                                                <% 
                                                    const todayStr = new Date().toISOString().split('T')[0];
                                                    const attToday = member.attendance.find(a => a.date === todayStr);
                                                    const status = attToday ? attToday.status : 'absent';
                                                %>
                                                <span class="label <%= status === 'present' ? 'label-success' : 'label-danger' %>">
                                                    <%= status.toUpperCase() %>
                                                </span>
                                            </td>
                                            <% if (user.role === 'society_admin') { %>
                                                <td>
                                                    <div style="display:flex; gap: 5px;">
                                                        <form action="/staff/attendance" method="POST" style="display:inline;">
                                                            <input type="hidden" name="staffId" value="<%= member._id %>">
                                                            <input type="hidden" name="status" value="<%= status === 'present' ? 'absent' : 'present' %>">
                                                            <button type="submit" class="btn btn-default btn-xs"><i class="fas fa-calendar-check"></i> Toggle</button>
                                                        </form>
                                                        <form action="/staff/delete" method="POST" style="display:inline;">
                                                            <input type="hidden" name="staffId" value="<%= member._id %>">
                                                            <button type="submit" class="btn btn-danger btn-xs"><i class="fas fa-trash-alt"></i> Remove</button>
                                                        </form>
                                                    </div>
                                                </td>
                                            <% } %>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 20px;">No staff records found in the directory.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Add Staff Panel (Role Restricted) -->
        <div class="col-md-4">
            <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <div class="panel panel-default" style="border-top: 3px solid #4caf50 !important;">
                    <div class="panel-heading"><h4><i class="fas fa-user-plus"></i> Register New Staff</h4></div>
                    <div class="panel-body">
                        <form action="/staff/add" method="POST">
                            <div class="form-group">
                                <label>Staff Member Name:</label>
                                <input type="text" name="name" class="form-control" placeholder="Full Name" required>
                            </div>
                            <div class="form-group">
                                <label>Department Role:</label>
                                <select name="role" class="form-control">
                                    <option value="guard">Security Guard</option>
                                    <option value="housekeeper">Housekeeper</option>
                                    <option value="electrician">Electrician</option>
                                    <option value="plumber">Plumber</option>
                                    <option value="gardener">Gardener</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Phone Number:</label>
                                <input type="text" name="phoneNumber" class="form-control" placeholder="Mobile Number" required>
                            </div>
                            <button type="submit" class="btn btn-success btn-block"><i class="fas fa-plus-circle"></i> Add Staff Profile</button>
                        </form>
                    </div>
                </div>
            <% } else { %>
                <!-- Service Desk Widget for Residents -->
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-info-circle"></i> Service Request Rules</h4></div>
                    <div class="panel-body" style="font-size: 13px; line-height: 1.5; color: var(--text-secondary);">
                        - All listed society staff have verified identity records.<br>
                        - Dial the contacts listed to request personal plumbing, electrical, or cleaning support.<br>
                        - Rate staff performance directly inside closed complaints tickets to update their ratings.<br>
                        - For emergency support, use the Contacts SOS trigger.
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
