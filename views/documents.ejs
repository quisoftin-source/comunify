<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="row">
        <!-- Header -->
        <div class="col-md-12">
            <h2 style="color: #ff5722;"><i class="fas fa-folder-open"></i> Digital Document Vault</h2>
            <p class="text-muted">Access important society files, download tax invoices, and request NOC certificates.</p>
            <hr style="border-color: var(--border-glass);">
        </div>
    </div>

    <div class="row">
        <!-- Main Documents List & Filters -->
        <div class="col-md-8">
            <div class="panel panel-default">
                <div class="panel-heading" style="display: flex; justify-content: space-between; align-items: center;">
                    <h4><i class="fas fa-files-medical"></i> Society Document Repository</h4>
                    
                    <!-- Quick Search / Filter dropdown -->
                    <form class="form-inline" style="margin-bottom: 0;">
                        <select id="docTypeFilter" class="form-control input-sm" onchange="filterDocs(this.value)">
                            <option value="all">All Document Types</option>
                            <option value="bylaws">Society Bylaws</option>
                            <option value="minutes">AGM Minutes</option>
                            <option value="noc">No Objection Certificates (NOC)</option>
                            <option value="share_certificate">Share Certificates</option>
                            <option value="invoice">Maintenance Invoices</option>
                            <option value="audit">Audit Reports</option>
                        </select>
                    </form>
                </div>
                <div class="panel-body">
                    <% if (documents && documents.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>File Name</th>
                                        <th>Category</th>
                                        <th>Size</th>
                                        <th>Date Uploaded</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="docsTableBody">
                                    <% documents.forEach(function(doc) { %>
                                        <tr class="doc-row" data-type="<%= doc.fileType %>">
                                            <td>
                                                <i class="far fa-file-pdf" style="color: #ff3b30; margin-right: 8px; font-size: 16px;"></i>
                                                <strong><%= doc.fileName %></strong>
                                            </td>
                                            <td>
                                                <span class="label label-default"><%= doc.fileType.toUpperCase().replace('_', ' ') %></span>
                                            </td>
                                            <td><%= (doc.fileSize / 1024).toFixed(1) %> KB</td>
                                            <td><%= new Date(doc.createdAt).toLocaleString().split(', ')[0] %></td>
                                            <td>
                                                <a href="/documents/download/<%= doc._id %>" class="btn btn-primary btn-xs" target="_blank">
                                                    <i class="fas fa-download"></i> View/Download
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 20px;">No public documents uploaded in the vault yet.</p>
                    <% } %>
                </div>
            </div>
            
            <!-- NOC Request Panel -->
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-certificate"></i> Request No Objection Certificate (NOC)</h4></div>
                <div class="panel-body">
                    <p class="text-muted" style="font-size: 13px;">Generate NOC documents for Passport, Sale, Mortgage, Rental, or Renovation purposes.</p>
                    <form action="/documents/noc/request" method="POST">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>NOC Category Type:</label>
                                    <select name="nocType" class="form-control" required>
                                        <option value="Passport verification">Passport verification</option>
                                        <option value="Property Selling permission">Property Selling permission</option>
                                        <option value="Bank Loan/Mortgage request">Bank Loan/Mortgage request</option>
                                        <option value="Tenant occupancy agreement">Tenant occupancy agreement</option>
                                        <option value="Flat Renovation authorization">Flat Renovation authorization</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Additional Notes / Purpose Details:</label>
                                    <input type="text" name="notes" class="form-control" placeholder="e.g. Bank loan for SBI" required>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-warning btn-sm"><i class="fas fa-file-signature"></i> Submit NOC Request</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Document Upload Panel (Role Restricted) -->
        <div class="col-md-4">
            <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <div class="panel panel-default" style="border-top: 3px solid #ff5722 !important;">
                    <div class="panel-heading"><h4><i class="fas fa-upload"></i> Upload Society Document</h4></div>
                    <div class="panel-body">
                        <form action="/documents/upload" method="POST">
                            <div class="form-group">
                                <label>File Name/Title:</label>
                                <input type="text" name="fileName" class="form-control" placeholder="e.g. AGM_Minutes_2025.pdf" required>
                            </div>
                            <div class="form-group">
                                <label>Document Category:</label>
                                <select name="fileType" class="form-control">
                                    <option value="bylaws">Society Bylaws</option>
                                    <option value="minutes">AGM Minutes</option>
                                    <option value="noc">No Objection Certificates (NOC)</option>
                                    <option value="share_certificate">Share Certificate</option>
                                    <option value="invoice">Maintenance Invoices</option>
                                    <option value="audit">Audit Report</option>
                                    <option value="other">Other Document</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Simulated Document Size (KB):</label>
                                <input type="number" name="fileSize" class="form-control" value="250" required>
                            </div>
                            <button type="submit" class="btn btn-success btn-block"><i class="fas fa-cloud-upload-alt"></i> Upload to Vault</button>
                        </form>
                    </div>
                </div>

                <!-- Admin NOC Manager Panel -->
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-tasks"></i> Pending NOC Requests</h4></div>
                    <div class="panel-body">
                        <% if (pendingNocs && pendingNocs.length > 0) { %>
                            <div style="max-height: 250px; overflow-y: auto;">
                                <% pendingNocs.forEach(function(noc) { %>
                                    <div style="border-bottom: 1px solid var(--border-glass); padding-bottom: 10px; margin-bottom: 10px; font-size: 12px;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                                            <strong>Flat <%= noc.uploadedBy %> (NOC)</strong>
                                            <form action="/documents/noc/approve" method="POST" style="display:inline;">
                                                <input type="hidden" name="nocId" value="<%= noc._id %>">
                                                <button type="submit" class="btn btn-success btn-xs"><i class="fas fa-check"></i> Approve</button>
                                            </form>
                                        </div>
                                        <p style="margin-bottom: 0;" class="text-muted">Type: <strong><%= docTypeFilter = noc.fileName.replace('NOC_Request_', '').replace('.pdf', '') %></strong></p>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <p class="text-muted text-center" style="font-size: 13px; padding: 10px 0;">No pending NOC requests at this time.</p>
                        <% } %>
                    </div>
                </div>
            <% } else { %>
                <!-- Storage Quota Widget for Residents -->
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-shield-alt"></i> Secure Document Storage</h4></div>
                    <div class="panel-body" style="font-size: 13px; line-height: 1.5;">
                        <p class="text-muted">All uploaded files are isolated within your housing society's secure partition and encrypted with AES-256 equivalent standards.</p>
                        <p class="text-muted">If you are missing your **Share Certificate** or **NOC**, please file a request or contact the management committee.</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    function filterDocs(type) {
        const rows = document.querySelectorAll('.doc-row');
        rows.forEach(row => {
            if (type === 'all' || row.dataset.type === type) {
                row.style.display = 'table-row';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>

<%- include('partials/footer') %>
