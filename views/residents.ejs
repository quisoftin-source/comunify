<%- include('partials/header') %>

<div style="padding:4%; padding-top:0%; font-family:sans-serif;font-size: 15px;">
  <% if(isAdmin && appliedResidents.length){ %>
    <div style="max-width:1000px; text-align:center; margin:auto; display:block; padding:20px 10% 10px; background-color:rgb(233, 233, 233); border-radius:0.5rem; box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); margin-bottom: 20px;">
      <div style="background-color:lightslategray; color:white; padding:1px 0; border-radius:0.5rem; max-width:500px; margin:auto; display:block; margin-bottom:10px">
        <h4>Approve New Residents</h4>
      </div>
      <form action="/approveResident" method="POST">
        <% appliedResidents.forEach(user => { %>
          <div style="max-width:500px; text-align:center; margin:auto; display:block; padding:10px 10%;background-color:whitesmoke; border-radius:0.5rem; box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.01); margin-bottom: 10px;">
            <p><%= user.firstName %> <%= user.lastName %> - <%= user.flatNumber %></p>
            <div>
              <button style="margin-top: 0; border-radius: 15px;" class="btn btn-success btn-sm" type="submit" name=validate[<%= user._id %>] value="approved"><i class="fas fa-check-circle fa-2x"></i></button>
              <button style="margin-top: 0; border-radius: 15px;" class="btn btn-danger btn-sm" type="submit" name=validate[<%= user._id %>] value="declined"><i class="fas fa-times-circle fa-2x"></i></button>
            </div>
          </div>
        <% }) %>
      </form>
    </div>
  <% } %>
  <% if(isAdmin) { %>
    <div style="max-width:1000px; margin:auto; margin-bottom: 25px; padding:20px; background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass); border-radius: 1rem;">
      <h4 style="color: #ff9800; font-weight: bold; margin-bottom: 15px;"><i class="fas fa-robot"></i> Interactive Resident Onboarding Assistant</h4>
      <p class="text-muted" style="font-size: 13px;">Onboard a new resident into the society registry. All inputs will be validated dynamically before save.</p>
      
      <form action="/residents/add" method="POST" id="onboardingForm" style="margin-top: 15px;">
        <div class="row">
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Tower (Building Block/Phase)*</label>
            <input type="text" name="tower" class="form-control" placeholder="e.g. Block A" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">H.No (Flat/Unit number)*</label>
            <input type="text" name="hNo" class="form-control" placeholder="e.g. 402" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Name (Resident's Full Name)*</label>
            <input type="text" name="name" class="form-control" placeholder="e.g. Rajesh Kumar" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
        </div>

        <div class="row">
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Contact Number*</label>
            <input type="tel" name="phoneNumber" class="form-control" placeholder="e.g. +919876543210" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Email Address*</label>
            <input type="email" name="email" class="form-control" placeholder="e.g. rajesh@email.com" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Father Name / Guardian</label>
            <input type="text" name="fatherName" class="form-control" placeholder="e.g. Ramesh Kumar" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
        </div>

        <div class="row">
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Occupancy Status*</label>
            <select name="occupancyType" class="form-control" id="occupancyType" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass); height: auto; padding: 6px 12px;">
              <option value="owner" style="background: #222;">Owner</option>
              <option value="renter" style="background: #222;">Renter</option>
            </select>
          </div>
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Kids Count</label>
            <input type="number" name="kidsCount" class="form-control" min="0" value="0" placeholder="0" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-4 form-group" id="ownerContactGroup" style="display: none;">
            <label style="color: #fff; font-weight: 500;">Owner Contact (Required if Renter)*</label>
            <input type="tel" name="ownerPhoneNumber" id="ownerPhoneNumber" class="form-control" placeholder="e.g. +919123456789" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
        </div>

        <div class="row">
          <div class="col-sm-3 form-group">
            <label style="color: #fff; font-weight: 500;">4 Wheeler Count</label>
            <input type="number" name="fourWheelerCount" class="form-control" min="0" value="0" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-3 form-group">
            <label style="color: #fff; font-weight: 500;">4 Wheeler Numbers</label>
            <input type="text" name="fourWheelerNumbers" class="form-control" placeholder="e.g. KA-03-MM-5678" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-3 form-group">
            <label style="color: #fff; font-weight: 500;">2 Wheeler Count</label>
            <input type="number" name="twoWheelerCount" class="form-control" min="0" value="0" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-3 form-group">
            <label style="color: #fff; font-weight: 500;">2 Wheeler Numbers</label>
            <input type="text" name="twoWheelerNumbers" class="form-control" placeholder="e.g. KA-01-AB-1234" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
        </div>

        <div class="row">
          <div class="col-sm-8 form-group">
            <label style="color: #fff; font-weight: 500;">Kids Names (separated by commas if multiple)</label>
            <input type="text" name="kidsNamesInput" class="form-control" placeholder="e.g. Aryan, Diya" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
          <div class="col-sm-4 form-group">
            <label style="color: #fff; font-weight: 500;">Bicycle Count</label>
            <input type="number" name="bicycleCount" class="form-control" min="0" value="0" style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
          </div>
        </div>

        <div class="form-group">
          <label style="color: #fff; font-weight: 500;">Supplementary Notes / Remarks</label>
          <textarea name="additionalInfo" class="form-control" rows="2" placeholder="Any additional notes..." style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);"></textarea>
        </div>

        <button type="submit" class="btn btn-warning"><i class="fas fa-plus-circle"></i> Onboard Resident</button>
      </form>

      <script>
        document.getElementById('occupancyType').addEventListener('change', function() {
          const group = document.getElementById('ownerContactGroup');
          const input = document.getElementById('ownerPhoneNumber');
          if (this.value === 'renter') {
            group.style.display = 'block';
            input.setAttribute('required', 'required');
          } else {
            group.style.display = 'none';
            input.removeAttribute('required');
          }
        });
      </script>
    </div>
  <% } %>

  <h2 style="background-color:rgb(51, 51, 51); padding:18px;color:white; text-align: center; border-radius: 1rem; font-size: 20px; max-width: 1000px; margin: auto; margin-bottom: 30px;">
      Residents of <%= societyName %>
  </h2>

  <div style="max-width:1000px; margin:auto; overflow-x:auto; background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass); border-radius: 1rem; padding: 15px; margin-bottom: 30px;">
    <table class="table table-striped table-hover" style="color: #fff; margin-bottom: 0; min-width: 1200px;">
      <thead>
        <tr style="border-bottom: 2px solid var(--accent-cyan);">
          <th style="color: var(--accent-cyan);">Tower</th>
          <th style="color: var(--accent-cyan);">H.No</th>
          <th style="color: var(--accent-cyan);">Name</th>
          <th style="color: var(--accent-cyan);">Contact</th>
          <th style="color: var(--accent-cyan);">Email</th>
          <th style="color: var(--accent-cyan);">Father Name</th>
          <th style="color: var(--accent-cyan);">Occupancy</th>
          <th style="color: var(--accent-cyan);">Kids Count</th>
          <th style="color: var(--accent-cyan);">Kids Name</th>
          <th style="color: var(--accent-cyan);">4W Count</th>
          <th style="color: var(--accent-cyan);">4W Plates</th>
          <th style="color: var(--accent-cyan);">2W Count</th>
          <th style="color: var(--accent-cyan);">2W Plates</th>
          <th style="color: var(--accent-cyan);">Bicycle Count</th>
          <th style="color: var(--accent-cyan);">Remarks</th>
        </tr>
      </thead>
      <tbody>
        <% if (societyResidents && societyResidents.length > 0) { %>
          <% societyResidents.forEach((resident) => { %>
            <% 
              let tower = 'Default';
              let hNo = resident.flatNumber || 'TBD';
              if (resident.flatNumber && resident.flatNumber.includes('-')) {
                  const parts = resident.flatNumber.split('-');
                  tower = parts[0].trim();
                  hNo = parts.slice(1).join('-').trim();
              }
              let kidsNamesStr = 'N/A';
              if (resident.kidsNames && resident.kidsNames.length > 0) {
                  kidsNamesStr = resident.kidsNames.map((name, i) => `${i + 1}. ${name.trim()}`).join(', ');
              }
            %>
            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); background: transparent !important;">
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= tower %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= hNo %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05); font-weight: bold; color: #fff;"><%= resident.firstName %> <%= resident.lastName %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.phoneNumber %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.username %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.fatherName || 'N/A' %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);">
                <span class="label <%= resident.occupancyType === 'renter' ? 'label-warning' : 'label-success' %>" style="text-transform: uppercase; font-size: 11px;">
                  <%= resident.occupancyType || 'owner' %>
                </span>
              </td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.kidsCount || 0 %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= kidsNamesStr %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.fourWheelerCount || 0 %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.fourWheelerNumbers || 'N/A' %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.twoWheelerCount || 0 %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.twoWheelerNumbers || 'N/A' %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05);"><%= resident.bicycleCount || 0 %></td>
              <td style="border-top: 1px solid rgba(255,255,255,0.05); font-size: 12px; max-width: 250px; word-wrap: break-word; color: #cbd5e1;">
                <% if (resident.occupancyType === 'renter' && resident.ownerPhoneNumber) { %>
                  <strong>Owner Contact:</strong> +<%= resident.ownerPhoneNumber %><br>
                <% } %>
                <%= resident.additionalInfo || '' %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="15" class="text-center text-muted" style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.05);">No registered residents in the database.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>