<%- include('partials/header') %>

<style>
    :root {
        --glass-bg: rgba(22, 28, 45, 0.4);
        --glass-border: rgba(255, 255, 255, 0.08);
        --accent-purple: #9c27b0;
        --accent-purple-light: #e040fb;
        --accent-cyan: #00bcd4;
        --accent-orange: #ff9800;
        --text-bright: #f8fafc;
        --text-dim: #94a3b8;
        --card-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    }

    body {
        background-color: #0b0f19;
        font-family: 'Inter', 'Outfit', sans-serif;
    }

    .glass-panel {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        padding: 24px;
        margin-bottom: 24px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .glass-panel:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.4);
    }

    .nav-tabs-custom {
        border-bottom: 1px solid var(--glass-border);
        margin-bottom: 30px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .nav-tabs-custom > li > a {
        background: transparent;
        border: 1px solid transparent;
        color: var(--text-dim);
        border-radius: 30px;
        padding: 10px 20px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .nav-tabs-custom > li.active > a, 
    .nav-tabs-custom > li > a:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        color: var(--text-bright) !important;
        border: 1px solid var(--glass-border) !important;
        box-shadow: inset 0 0 8px rgba(255,255,255,0.02);
    }

    .nav-tabs-custom > li.active > a {
        background: linear-gradient(135deg, var(--accent-purple), var(--accent-purple-light)) !important;
        border-color: transparent !important;
        color: white !important;
    }

    .category-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        display: inline-block;
    }

    .category-Maintenance { background: rgba(244, 63, 94, 0.15); color: #f43f5e; }
    .category-Security { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .category-Parking { background: rgba(234, 179, 8, 0.15); color: #eab308; }
    .category-Events { background: rgba(168, 85, 247, 0.15); color: #a855f7; }
    .category-Budget { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
    .category-General { background: rgba(100, 116, 139, 0.15); color: #64748b; }

    .comment-box {
        border-left: 2px solid var(--glass-border);
        padding-left: 15px;
        margin-top: 15px;
        background: rgba(255, 255, 255, 0.01);
        border-radius: 0 8px 8px 0;
        padding: 10px 15px;
    }

    .vote-option-btn {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        padding: 15px;
        display: flex;
        align-items: center;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
        margin-bottom: 10px;
        color: var(--text-bright);
    }

    .vote-option-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--accent-purple-light);
    }

    .vote-option-btn input[type="radio"] {
        margin-right: 15px;
        transform: scale(1.3);
        accent-color: var(--accent-purple-light);
    }

    .engagement-gauge {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: radial-gradient(closest-side, #0b0f19 82%, transparent 0% 100%),
                    conic-gradient(var(--accent-cyan) calc(var(--percent) * 1%), rgba(255,255,255,0.05) 0);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
    }

    .suggestion-card {
        border-right: 4px solid var(--accent-orange);
    }

    .btn-action {
        border-radius: 20px;
        padding: 6px 16px;
        font-weight: 600;
        font-size: 12px;
        text-transform: none;
    }

    .btn-convert {
        background: linear-gradient(135deg, var(--accent-orange), #ff5722);
        color: #white;
        border: none;
    }

    .btn-convert:hover {
        opacity: 0.9;
        color: white;
    }
</style>

<div class="container" style="margin-top: 30px; margin-bottom: 60px;">
    <!-- Title Section -->
    <div class="row" style="margin-bottom: 15px;">
        <div class="col-sm-12">
            <h2 style="color: var(--accent-purple-light); font-weight: 800; letter-spacing: -0.5px;">
                <i class="fas fa-users-cog"></i> Community Engagement Hub
            </h2>
            <p class="text-muted">A collaborative platform for discussion, voting on key resolutions, suggestions, and feedback surveys.</p>
            <hr style="border-color: var(--glass-border);">
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="row">
        <div class="col-md-12">
            <ul class="nav nav-tabs nav-tabs-custom" id="hubTabs">
                <li class="active"><a href="#discussions" data-toggle="tab"><i class="far fa-comments"></i> Discussions</a></li>
                <li><a href="#voting" data-toggle="tab"><i class="fas fa-vote-yea"></i> E-Voting</a></li>
                <li><a href="#surveys" data-toggle="tab"><i class="fas fa-poll-h"></i> Surveys</a></li>
                <li><a href="#suggestions" data-toggle="tab"><i class="far fa-lightbulb"></i> Suggestions</a></li>
                <li><a href="#announcements" data-toggle="tab"><i class="fas fa-bullhorn"></i> Announcements</a></li>
                <li><a href="#analytics" data-toggle="tab"><i class="fas fa-chart-pie"></i> Hub Analytics</a></li>
            </ul>
        </div>
    </div>

    <div class="tab-content" style="margin-top: 15px;">

        <!-- 1. DISCUSSIONS TAB -->
        <div class="tab-pane active" id="discussions">
            <div class="row">
                <!-- Topics list -->
                <div class="col-md-8">
                    <div class="glass-panel" style="padding-top: 15px;">
                        <h4 style="color: #fff; font-weight: bold; margin-bottom: 20px;"><i class="far fa-list-alt"></i> Active Discussion Threads</h4>
                        
                        <% if (discussions && discussions.length > 0) { %>
                            <% discussions.forEach(function(topic) { %>
                                <div class="glass-panel" style="background: rgba(255,255,255,0.01); border-radius: 12px; padding: 20px; margin-bottom: 15px;">
                                    <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-bottom: 10px;">
                                        <div>
                                            <span class="category-badge category-<%= ['Maintenance', 'Security', 'Parking', 'Events', 'Budget'].includes(topic.category) ? topic.category : 'General' %>">
                                                <%= topic.category %>
                                            </span>
                                            <% if (topic.status === 'converted') { %>
                                                <span class="label label-success" style="margin-left: 5px;">CONVERTED TO VOTE</span>
                                            <% } %>
                                        </div>
                                        <small class="text-muted"><%= new Date(topic.createdAt).toLocaleString() %></small>
                                    </div>
                                    <h4 style="color: #fff; font-weight: bold; margin-top: 5px;"><%= topic.title %></h4>
                                    <p style="color: var(--text-dim); line-height: 1.6; white-space: pre-line;"><%= topic.description %></p>

                                    <!-- Attachments display -->
                                    <% if (topic.attachments && topic.attachments.length > 0) { %>
                                        <div style="margin: 15px 0;">
                                            <h5 style="color: #fff; font-size:12px; font-weight:bold;">Attachments:</h5>
                                            <% topic.attachments.forEach(function(att) { %>
                                                <span class="label label-default" style="margin-right: 5px; padding: 5px 10px; display:inline-block; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border);">
                                                    <i class="far <%= att.fileType === 'pdf' ? 'fa-file-pdf text-danger' : 'fa-file-image text-info' %>"></i>
                                                    <%= att.name %>
                                                </span>
                                            <% }); %>
                                        </div>
                                    <% } %>

                                    <hr style="border-color: var(--glass-border); margin: 15px 0;">

                                    <!-- Footer Stats & Actions -->
                                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; font-size: 13px;">
                                        <div style="color: var(--text-dim);">
                                            <span>By: <strong><%= topic.createdBy.name %></strong> (<%= topic.createdBy.role.replace('_', ' ') %>)</span>
                                            <span style="margin: 0 10px;">|</span>
                                            <span><i class="far fa-comment-dots"></i> <%= topic.comments.length %> comments</span>
                                        </div>
                                        <div style="display: flex; gap: 10px;">
                                            <form action="/community-hub/discussion/<%= topic._id %>/follow" method="POST" style="display:inline;">
                                                <button type="submit" class="btn btn-default btn-xs btn-action">
                                                    <i class="<%= topic.followers.includes(user.id) ? 'fas fa-bell text-warning' : 'far fa-bell' %>"></i> 
                                                    <%= topic.followers.includes(user.id) ? 'Following' : 'Follow' %>
                                                </button>
                                            </form>
                                            
                                            <% if ((user.role === 'society_admin' || user.role === 'committee_member') && topic.status === 'active') { %>
                                                <form action="/community-hub/discussion/<%= topic._id %>/convert-to-vote" method="POST" style="display:inline;">
                                                    <button type="submit" class="btn btn-warning btn-xs btn-action btn-convert">
                                                        <i class="fas fa-exchange-alt"></i> Convert to Vote
                                                    </button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </div>

                                    <!-- Comments section -->
                                    <div style="margin-top: 20px;">
                                        <h5 style="color: #fff; font-weight: bold;"><i class="far fa-comments"></i> Conversation</h5>
                                        <% if (topic.comments && topic.comments.length > 0) { %>
                                            <% topic.comments.forEach(function(comment) { %>
                                                <div class="comment-box">
                                                    <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                                                        <strong style="color: #00bcd4; font-size:12px;"><%= comment.createdBy.name %></strong>
                                                        <small class="text-muted"><%= new Date(comment.createdAt).toLocaleDateString() %></small>
                                                    </div>
                                                    <p style="color: var(--text-bright); margin-bottom: 5px; font-size:13px;"><%= comment.text %></p>
                                                    
                                                    <!-- Comment footer (Likes/Replies) -->
                                                    <div style="display:flex; gap: 15px; font-size:11px; align-items:center;">
                                                        <form action="/community-hub/discussion/<%= topic._id %>/comment/<%= comment._id %>/like" method="POST" style="margin:0;">
                                                            <button type="submit" class="btn-link" style="padding:0; border:none; background:none; color: var(--text-dim);">
                                                                <i class="far fa-thumbs-up <%= comment.likes.includes(user.id) ? 'text-primary' : '' %>"></i> 
                                                                <%= comment.likes.length %> Likes
                                                            </button>
                                                        </form>
                                                        <a href="javascript:void(0)" onclick="$('#reply-form-<%= comment._id %>').toggle()" style="color: var(--text-dim);">
                                                            <i class="far fa-reply"></i> Reply
                                                        </a>
                                                    </div>

                                                    <!-- Comment Replies List -->
                                                    <% if (comment.replies && comment.replies.length > 0) { %>
                                                        <div style="margin-left: 20px; margin-top: 8px;">
                                                            <% comment.replies.forEach(function(reply) { %>
                                                                <div style="background: rgba(255,255,255,0.005); border-left: 1px solid var(--accent-purple-light); padding: 5px 10px; margin-bottom: 5px; border-radius: 0 4px 4px 0;">
                                                                    <div style="display:flex; justify-content:space-between; font-size:11px;">
                                                                        <strong style="color: var(--accent-purple-light);"><%= reply.createdBy.name %></strong>
                                                                        <small class="text-muted"><%= new Date(reply.createdAt).toLocaleDateString() %></small>
                                                                    </div>
                                                                    <p style="font-size:12px; margin-bottom:0; color:#eee;"><%= reply.text %></p>
                                                                </div>
                                                            <% }); %>
                                                        </div>
                                                    <% } %>

                                                    <!-- Reply Input box -->
                                                    <div id="reply-form-<%= comment._id %>" style="display:none; margin-top:10px; margin-left: 20px;">
                                                        <form action="/community-hub/discussion/<%= topic._id %>/comment/<%= comment._id %>/reply" method="POST">
                                                            <div class="input-group">
                                                                <input type="text" name="text" class="form-control input-sm" placeholder="Write reply..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                                                <span class="input-group-btn">
                                                                    <button type="submit" class="btn btn-purple btn-sm" style="background: var(--accent-purple); color:white;"><i class="fas fa-reply"></i></button>
                                                                </span>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <p class="text-muted" style="font-size: 12px; margin-top:10px;">No comments posted yet. Be the first!</p>
                                        <% } %>

                                        <!-- Add comment form -->
                                        <form action="/community-hub/discussion/<%= topic._id %>/comment" method="POST" style="margin-top: 15px;">
                                            <div class="input-group">
                                                <input type="text" name="text" class="form-control" placeholder="Write a comment..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                                <span class="input-group-btn">
                                                    <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Comment</button>
                                                </span>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center" style="padding: 40px 0;">No active discussion topics found. Click the start button on the right to post.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Discussion creation side panel -->
                <div class="col-md-4">
                    <div class="glass-panel" style="border-top: 4px solid var(--accent-purple-light);">
                        <h4 style="color: #fff; font-weight: bold;"><i class="fas fa-edit"></i> Start a Discussion</h4>
                        <p class="text-muted" style="font-size:13px;">Propose rules, start discussions, or raise security/utility inquiries.</p>
                        <hr style="border-color: var(--glass-border);">

                        <form action="/community-hub/discussion/create" method="POST">
                            <div class="form-group">
                                <label style="color:#eee;">Title / Topic Headline:</label>
                                <input type="text" name="title" class="form-control" placeholder="e.g. Visitor parking spacing rules" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                            </div>
                            <div class="form-group">
                                <label style="color:#eee;">Category:</label>
                                <select name="category" class="form-control" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                    <option value="General Discussion">General Discussion</option>
                                    <option value="Maintenance">Maintenance</option>
                                    <option value="Security">Security</option>
                                    <option value="Parking">Parking</option>
                                    <option value="Events">Events</option>
                                    <option value="Rules & Regulations">Rules & Regulations</option>
                                    <option value="Budget">Budget</option>
                                    <option value="Infrastructure">Infrastructure</option>
                                    <option value="Water Supply">Water Supply</option>
                                    <option value="Electricity">Electricity</option>
                                    <option value="Housekeeping">Housekeeping</option>
                                    <option value="New Proposal">New Proposal</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label style="color:#eee;">Detailed Description:</label>
                                <textarea name="description" class="form-control" rows="5" placeholder="Elaborate details for community view..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);"></textarea>
                            </div>

                            <!-- Mock upload fields for PDF/Images -->
                            <div class="form-group">
                                <label style="color:#eee;"><i class="fas fa-paperclip"></i> Attachment Simulation (Optional):</label>
                                <input type="text" name="attachmentName" class="form-control" placeholder="e.g. proposed_layout.pdf / parking_pic.png" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border); margin-bottom:5px;">
                                <input type="hidden" name="attachmentPath" value="/uploads/mock_layout.pdf">
                            </div>

                            <button type="submit" class="btn btn-purple btn-block" style="background: var(--accent-purple); color:white;"><i class="fas fa-plus-circle"></i> Publish Thread</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. E-VOTING TAB -->
        <div class="tab-pane" id="voting">
            <div class="row">
                <!-- Polls Listing -->
                <div class="col-md-8">
                    <div class="glass-panel">
                        <h4 style="color:#fff; font-weight:bold; margin-bottom:20px;"><i class="fas fa-ballot"></i> Active Voting & Resolutions</h4>
                        
                        <% if (polls && polls.length > 0) { %>
                            <% polls.forEach(function(poll) { %>
                                <%
                                    // Check signature or hash to ensure tamper protection
                                    const crypto = require('crypto');
                                    const userIdHash = crypto.createHash('sha256').update(user.id + (process.env.SESSION_SECRET || 'danish_society_secret_key')).digest('hex');
                                    const hasVoted = poll.votes.some(v => v.userIdHash === userIdHash);
                                    const userVote = hasVoted ? poll.votes.find(v => v.userIdHash === userIdHash).option : null;
                                    const totalVotes = poll.votes.length;
                                    
                                    // Quorum check
                                    const quorumMet = (totalVotes >= (totalResidents * (poll.quorumRequirement || 0) / 100));
                                %>
                                <div class="glass-panel" style="background: rgba(255,255,255,0.01); border-radius:12px; border-left: 4px solid var(--accent-purple-light); padding:20px; margin-bottom:15px;">
                                    <div style="display:flex; justify-content:space-between; margin-bottom:10px; align-items:center;">
                                        <span class="label label-purple" style="background:var(--accent-purple);"><%= poll.type.toUpperCase().replace('_', ' ') %></span>
                                        <span class="text-muted" style="font-size:12px;"><i class="fas fa-check-double"></i> Quorum Req: <%= poll.quorumRequirement %>% (Met: <%= quorumMet ? 'Yes' : 'No' %>)</span>
                                    </div>
                                    <h4 style="color:#fff; font-weight:bold;"><%= poll.question %></h4>
                                    <% if (poll.description) { %>
                                        <p class="text-muted" style="font-size:13px; line-height:1.5;"><%= poll.description %></p>
                                    <% } %>
                                    <small class="text-muted">Expiry Date: <%= new Date(poll.endDate).toLocaleDateString() %></small>
                                    
                                    <hr style="border-color:var(--glass-border); margin:15px 0;">

                                    <% if (hasVoted) { %>
                                        <!-- Voted -> Display results bar charts -->
                                        <div>
                                            <p class="text-success" style="font-weight:bold;"><i class="fas fa-check-circle"></i> Your ballot is cast: Option "<%= userVote %>"</p>
                                            <h5 style="color:#eee; font-weight:bold; margin-bottom:10px;">Live Standing:</h5>
                                            
                                            <% poll.options.forEach(function(opt) { %>
                                                <%
                                                    const optVotes = poll.votes.filter(v => v.option === opt).length;
                                                    const pct = totalVotes > 0 ? ((optVotes / totalVotes) * 100) : 0;
                                                %>
                                                <div style="margin-bottom:12px;">
                                                    <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:4px;">
                                                        <span style="color:#eee;"><%= opt %></span>
                                                        <span class="text-muted"><%= pct.toFixed(1) %>% (<%= optVotes %> votes)</span>
                                                    </div>
                                                    <div class="progress" style="height:10px; background:rgba(255,255,255,0.05); margin-bottom:0;">
                                                        <div class="progress-bar" style="width: <%= pct %>%; background: linear-gradient(90deg, var(--accent-purple), var(--accent-purple-light));"></div>
                                                    </div>
                                                </div>
                                            <% }); %>
                                        </div>
                                    <% } else { %>
                                        <!-- Vote form with OTP validation flow -->
                                        <form id="vote-form-<%= poll._id %>" action="/community-hub/voting/cast" method="POST">
                                            <input type="hidden" name="pollId" value="<%= poll._id %>">
                                            <div style="display:flex; flex-direction:column; gap:10px; margin-bottom:15px;">
                                                <% poll.options.forEach(function(opt) { %>
                                                    <label class="vote-option-btn">
                                                        <input type="radio" name="option" value="<%= opt %>" required>
                                                        <%= opt %>
                                                    </label>
                                                <% }); %>
                                            </div>

                                            <!-- Secure OTP Verification UI trigger -->
                                            <div id="otp-area-<%= poll._id %>" style="display:none; margin-bottom:15px; padding:15px; border:1px solid var(--glass-border); border-radius:8px; background:rgba(0,0,0,0.2);">
                                                <label style="color:#fff;">Enter Secure Vote OTP sent via SMS/WhatsApp:</label>
                                                <input type="text" name="otp" id="otp-input-<%= poll._id %>" class="form-control" placeholder="6-digit OTP code" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border); width:200px;">
                                                <p class="text-muted" style="font-size:11px; margin-top:5px;">Check simulation Whatsapp logs on Home screen for OTP.</p>
                                            </div>

                                            <button type="button" id="submit-trigger-<%= poll._id %>" onclick="requestOTP('<%= poll._id %>')" class="btn btn-purple" style="background:var(--accent-purple); color:white;"><i class="fas fa-shield-alt"></i> Request OTP & Vote</button>
                                            <button type="submit" id="submit-final-<%= poll._id %>" style="display:none;" class="btn btn-success"><i class="fas fa-check-circle"></i> Confirm Ballot</button>
                                        </form>
                                    <% } %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center" style="padding: 40px 0;">No active voting resolutions currently scheduled.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Create resolution side panel -->
                <div class="col-md-4">
                    <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                        <div class="glass-panel" style="border-top: 4px solid var(--accent-purple-light);">
                            <h4 style="color:#fff; font-weight:bold;"><i class="fas fa-plus"></i> New Resolution / Vote</h4>
                            <p class="text-muted" style="font-size:13px;">Initiate formal e-voting for rule shifts, AGM selections, or budget overrides.</p>
                            <hr style="border-color:var(--glass-border);">

                            <form action="/community-hub/voting/create" method="POST">
                                <div class="form-group">
                                    <label style="color:#eee;">Resolution Question:</label>
                                    <input type="text" name="question" class="form-control" placeholder="e.g. Approve 2026 tower paint expansion" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Short Details / Description:</label>
                                    <textarea name="description" class="form-control" rows="3" placeholder="Provide background details..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);"></textarea>
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Voting Type:</label>
                                    <select name="type" class="form-control" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                        <option value="yes_no">Yes / No / Abstain</option>
                                        <option value="single_choice">Single Choice</option>
                                        <option value="multiple_choice">Multiple Choice</option>
                                        <option value="budget">Budget Approval</option>
                                        <option value="election">Committee Elections</option>
                                        <option value="agm">AGM Resolution</option>
                                        <option value="rule_change">Rule Change</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Options (One per line):</label>
                                    <textarea name="optionsRaw" class="form-control" rows="3" placeholder="Yes&#10;No&#10;Abstain" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);"></textarea>
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Quorum Requirement (%):</label>
                                    <input type="number" name="quorumRequirement" class="form-control" min="0" max="100" value="20" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Anonymous Voting:</label>
                                    <select name="isAnonymous" class="form-control" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                        <option value="true">Yes (Hide voter names)</option>
                                        <option value="false">No (Public names)</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">End Date:</label>
                                    <input type="date" name="endDate" class="form-control" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                </div>
                                <button type="submit" class="btn btn-success btn-block"><i class="fas fa-plus-circle"></i> Publish Resolution</button>
                            </form>
                        </div>
                    <% } else { %>
                        <div class="glass-panel">
                            <h4 style="color:#fff; font-weight:bold;"><i class="fas fa-shield-alt"></i> Security & Auditing</h4>
                            <p style="font-size:13px; color:var(--text-dim); line-height:1.5;">
                                - Each flat is permitted exactly **one secure ballot**.<br>
                                - Ballots are verified using OTP to prevent voter spoofing.<br>
                                - Voter identification hashes (`SHA-256`) ensure anonymous results display without leaks.
                            </p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- 3. SURVEYS TAB -->
        <div class="tab-pane" id="surveys">
            <div class="row">
                <!-- Active Surveys Feed -->
                <div class="col-md-8">
                    <div class="glass-panel">
                        <h4 style="color:#fff; font-weight:bold; margin-bottom:20px;"><i class="fas fa-poll-h"></i> Active Community Surveys</h4>
                        
                        <% if (surveys && surveys.length > 0) { %>
                            <% surveys.forEach(function(survey) { %>
                                <%
                                    const hasResponded = survey.responses.some(r => r.userId === user.id);
                                    const totalResponses = survey.responses.length;
                                %>
                                <div class="glass-panel" style="background: rgba(255,255,255,0.01); border-radius:12px; padding:20px; margin-bottom:15px;">
                                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                                        <span class="label label-info"><%= survey.category.toUpperCase() %></span>
                                        <span class="text-muted" style="font-size:12px;"><i class="far fa-user"></i> <%= totalResponses %> responses</span>
                                    </div>
                                    <h4 style="color:#fff; font-weight:bold;"><%= survey.title %></h4>
                                    <p class="text-muted" style="font-size:13px;"><%= survey.description %></p>

                                    <hr style="border-color:var(--glass-border); margin:15px 0;">

                                    <% if (hasResponded) { %>
                                        <p class="text-info" style="font-weight:bold;"><i class="fas fa-check"></i> Thank you! You have submitted your feedback response.</p>
                                    <% } else { %>
                                        <form action="/community-hub/survey/<%= survey._id %>/submit" method="POST">
                                            <div style="display:flex; flex-direction:column; gap:20px; margin-bottom:20px;">
                                                <% survey.questions.forEach(function(q, qIdx) { %>
                                                    <div style="background:rgba(255,255,255,0.01); padding:15px; border-radius:8px; border: 1px solid var(--glass-border);">
                                                        <h5 style="color:#fff; font-weight:bold; margin-bottom:12px;"><%= qIdx + 1 %>. <%= q.text %></h5>
                                                        
                                                        <% if (q.type === 'text') { %>
                                                            <input type="text" name="ans_<%= qIdx %>" class="form-control" placeholder="Write response..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                                        <% } else if (q.type === 'rating') { %>
                                                            <div style="display:flex; gap:15px;">
                                                                <% for(let r = 1; r <= 5; r++) { %>
                                                                    <label style="cursor:pointer; color:var(--text-bright); display:flex; align-items:center; gap:5px;">
                                                                        <input type="radio" name="ans_<%= qIdx %>" value="<%= r %>" required> <%= r %> <i class="fas fa-star" style="color:#ff9800; font-size:12px;"></i>
                                                                    </label>
                                                                <% } %>
                                                            </div>
                                                        <% } else if (q.type === 'scale_rating') { %>
                                                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                                                <span class="text-muted">1 (Low)</span>
                                                                <input type="range" name="ans_<%= qIdx %>" min="1" max="10" step="1" style="width:70%; accent-color: var(--accent-cyan);">
                                                                <span class="text-muted">10 (High)</span>
                                                            </div>
                                                        <% } else if (q.type === 'single_choice') { %>
                                                            <% q.options.forEach(function(opt) { %>
                                                                <label style="display:block; cursor:pointer; color:var(--text-bright); margin-bottom:6px; font-weight:normal;">
                                                                    <input type="radio" name="ans_<%= qIdx %>" value="<%= opt %>" required> <%= opt %>
                                                                </label>
                                                            <% }); %>
                                                        <% } else if (q.type === 'checkbox') { %>
                                                            <% q.options.forEach(function(opt) { %>
                                                                <label style="display:block; cursor:pointer; color:var(--text-bright); margin-bottom:6px; font-weight:normal;">
                                                                    <input type="checkbox" name="ans_<%= qIdx %>" value="<%= opt %>"> <%= opt %>
                                                                </label>
                                                            <% }); %>
                                                        <% } %>
                                                    </div>
                                                <% }); %>
                                            </div>
                                            <button type="submit" class="btn btn-info btn-sm"><i class="fas fa-check"></i> Submit Feedback</button>
                                        </form>
                                    <% } %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center" style="padding: 40px 0;">No resident surveys published currently.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Create survey side panel -->
                <div class="col-md-4">
                    <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                        <div class="glass-panel" style="border-top: 4px solid var(--accent-cyan);">
                            <h4 style="color:#fff; font-weight:bold;"><i class="fas fa-plus"></i> Create Survey</h4>
                            <p class="text-muted" style="font-size:13px;">Publish event, utility, or general society satisfaction surveys.</p>
                            <hr style="border-color:var(--glass-border);">

                            <form action="/community-hub/survey/create" method="POST">
                                <div class="form-group">
                                    <label style="color:#eee;">Survey Title:</label>
                                    <input type="text" name="title" class="form-control" placeholder="e.g. Security Staff Satisfaction Survey" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Description:</label>
                                    <textarea name="description" class="form-control" rows="3" placeholder="Provide background..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);"></textarea>
                                </div>
                                <div class="form-group">
                                    <label style="color:#eee;">Category:</label>
                                    <select name="category" class="form-control" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                        <option value="satisfaction">Resident Satisfaction Survey</option>
                                        <option value="feedback">General Feedback Survey</option>
                                        <option value="maintenance">Maintenance Feedback</option>
                                        <option value="event">Event Feedback</option>
                                    </select>
                                </div>

                                <!-- Dynamic questions constructor -->
                                <div style="border: 1px solid var(--glass-border); padding: 10px; border-radius: 8px; margin-bottom: 15px;">
                                    <h5 style="color:#fff; font-weight:bold;">Question Config</h5>
                                    <div class="form-group">
                                        <label style="color:#ccc; font-size:12px;">Question Text:</label>
                                        <input type="text" name="qTexts" class="form-control input-sm" placeholder="e.g. Rate housekeeping quality" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                    </div>
                                    <div class="form-group">
                                        <label style="color:#ccc; font-size:12px;">Question Type:</label>
                                        <select name="qTypes" class="form-control input-sm" style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                                            <option value="rating">Star Rating (1-5 Stars)</option>
                                            <option value="scale_rating">Scale Rating (1-10 Slider)</option>
                                            <option value="text">Free Text Box</option>
                                        </select>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-info btn-block"><i class="fas fa-plus-circle"></i> Create Survey</button>
                            </form>
                        </div>
                    <% } else { %>
                        <div class="glass-panel">
                            <h4 style="color:#fff; font-weight:bold;"><i class="fas fa-info-circle"></i> Surveys info</h4>
                            <p style="font-size:13px; color:var(--text-dim); line-height:1.5;">
                                - Surveys are anonymous and aggregated automatically.<br>
                                - Results are mapped on the analytics charts to compute society happiness score.
                            </p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- 4. SUGGESTIONS TAB -->
        <div class="tab-pane" id="suggestions">
            <div class="row">
                <!-- Suggestions Feed -->
                <div class="col-md-8">
                    <div class="glass-panel">
                        <h4 style="color:#fff; font-weight:bold; margin-bottom:20px;"><i class="far fa-lightbulb"></i> Resident Suggestions Box</h4>
                        
                        <% if (suggestions && suggestions.length > 0) { %>
                            <% suggestions.forEach(function(sug) { %>
                                <%
                                    const score = sug.upvotes.length - sug.downvotes.length;
                                    const hasUpvoted = sug.upvotes.includes(user.id);
                                    const hasDownvoted = sug.downvotes.includes(user.id);
                                %>
                                <div class="glass-panel suggestion-card" style="background: rgba(255,255,255,0.01); border-radius:12px; padding:20px; margin-bottom:15px; display:flex; align-items:center; gap:20px;">
                                    <!-- Voting arrows -->
                                    <div style="display:flex; flex-direction:column; align-items:center; gap:5px;">
                                        <form action="/community-hub/suggestion/<%= sug._id %>/vote" method="POST" style="margin:0;">
                                            <input type="hidden" name="voteType" value="up">
                                            <button type="submit" class="btn-link" style="padding:0; border:none; background:none;">
                                                <i class="fas fa-chevron-up fa-lg <%= hasUpvoted ? 'text-success' : 'text-muted' %>"></i>
                                            </button>
                                        </form>
                                        <span style="font-weight:bold; font-size:16px; color:#fff;"><%= score %></span>
                                        <form action="/community-hub/suggestion/<%= sug._id %>/vote" method="POST" style="margin:0;">
                                            <input type="hidden" name="voteType" value="down">
                                            <button type="submit" class="btn-link" style="padding:0; border:none; background:none;">
                                                <i class="fas fa-chevron-down fa-lg <%= hasDownvoted ? 'text-danger' : 'text-muted' %>"></i>
                                            </button>
                                        </form>
                                    </div>
                                    
                                    <!-- Suggestion content -->
                                    <div style="flex-grow:1;">
                                        <h4 style="color:#fff; font-weight:bold; margin-top:0;"><%= sug.title %></h4>
                                        <p class="text-muted" style="margin-bottom:10px; line-height:1.5;"><%= sug.description %></p>
                                        <small class="text-muted">Proposed by Flat <%= sug.createdBy.flatNumber %> (<%= sug.createdBy.name %>)</small>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center" style="padding: 40px 0;">No suggestions submitted yet. Share your feedback!</p>
                        <% } %>
                    </div>
                </div>

                <!-- Submit Suggestion Form -->
                <div class="col-md-4">
                    <div class="glass-panel" style="border-top: 4px solid var(--accent-orange);">
                        <h4 style="color:#fff; font-weight:bold;"><i class="far fa-edit"></i> Submit Suggestion</h4>
                        <p class="text-muted" style="font-size:13px;">Submit suggestions to improve society security, amenities, or regulations.</p>
                        <hr style="border-color:var(--glass-border);">

                        <form action="/community-hub/suggestion/create" method="POST">
                            <div class="form-group">
                                <label style="color:#eee;">Suggestion Title:</label>
                                <input type="text" name="title" class="form-control" placeholder="e.g. CCTV inside elevator lobby" required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);">
                            </div>
                            <div class="form-group">
                                <label style="color:#eee;">Suggestion details:</label>
                                <textarea name="description" class="form-control" rows="5" placeholder="Detail your recommendation..." required style="background:rgba(0,0,0,0.3); color:white; border-color:var(--glass-border);"></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning btn-block" style="background:var(--accent-orange); border-color:var(--accent-orange); color:#fff;"><i class="fas fa-plus-circle"></i> Submit Box</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- 5. ANNOUNCEMENTS TAB -->
        <div class="tab-pane" id="announcements">
            <div class="row">
                <div class="col-md-12">
                    <div class="glass-panel">
                        <h4 style="color:#fff; font-weight:bold; margin-bottom:20px;"><i class="fas fa-bullhorn"></i> Official Announcements / Notices</h4>
                        
                        <% if (notices && notices.length > 0) { %>
                            <% notices.forEach(function(notice) { %>
                                <div class="glass-panel" style="background: rgba(255,255,255,0.015); border-radius:12px; padding:20px; margin-bottom:15px; border-left:4px solid var(--accent-cyan);">
                                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                                        <span class="label label-info" style="background:var(--accent-cyan);"><%= notice.date %></span>
                                    </div>
                                    <h4 style="color:#fff; font-weight:bold;"><%= notice.subject %></h4>
                                    <p style="color:var(--text-dim); line-height:1.6; white-space:pre-line;"><%= notice.details %></p>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted text-center" style="padding: 40px 0;">No official announcements listed.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- 6. ANALYTICS TAB -->
        <div class="tab-pane" id="analytics">
            <div class="row">
                <!-- Analytics counters -->
                <div class="col-md-4">
                    <div class="glass-panel text-center" style="border-top:4px solid var(--accent-cyan);">
                        <div class="engagement-gauge" style="--percent: <%= engagementScore %>;">
                            <span style="font-size:24px; font-weight:bold; color:var(--text-bright);"><%= engagementScore %>%</span>
                        </div>
                        <h4 style="color:#fff; font-weight:bold;">Community Engagement Score</h4>
                        <p class="text-muted" style="font-size:12px;">Measures total comments, voting, and survey activity scaled against approved residents.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-panel text-center" style="border-top:4px solid var(--accent-purple-light);">
                        <h1 style="color:#fff; font-weight:800; font-size:48px; margin: 10px 0;"><%= participationPercentage %>%</h1>
                        <h4 style="color:#fff; font-weight:bold;">E-Voting Participation Rate</h4>
                        <p class="text-muted" style="font-size:12px;">Quorum requirements assert resolutions require at least 20% participation to finalize.</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-panel text-center" style="border-top:4px solid var(--accent-orange);">
                        <h1 style="color:#fff; font-weight:800; font-size:48px; margin: 10px 0;"><%= satisfactionScore %>%</h1>
                        <h4 style="color:#fff; font-weight:bold;">Resident Satisfaction Index</h4>
                        <p class="text-muted" style="font-size:12px;">Derived from survey star ratings and questionnaire feedback logs.</p>
                    </div>
                </div>
            </div>

            <!-- Charts section -->
            <div class="row">
                <div class="col-md-6">
                    <div class="glass-panel">
                        <h4 style="color:#fff; font-weight:bold; margin-bottom:15px;"><i class="fas fa-chart-bar"></i> Active Topics Comment Standing</h4>
                        <canvas id="activeTopicsChart" style="height:250px;"></canvas>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="glass-panel">
                        <h4 style="color:#fff; font-weight:bold; margin-bottom:15px;"><i class="fas fa-chart-line"></i> Resident Activity Contributions</h4>
                        <canvas id="activityChart" style="height:250px;"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Scripts for dynamic OTP and Charts -->
<script>
    // secure OTP voting request
    function requestOTP(pollId) {
        $.post('/community-hub/voting/request-otp', {}, function(data) {
            if (data.success) {
                alert("Security Code Generated: A mock 6-digit OTP has been logged to the simulated WhatsApp logs desk. Type it in to confirm vote.");
                $('#otp-area-' + pollId).slideDown();
                $('#submit-trigger-' + pollId).hide();
                $('#submit-final-' + pollId).show();
            } else {
                alert("Failed to send OTP verification.");
            }
        });
    }

    // Chart.js plots
    $(document).ready(function() {
        // Active Topics Comments Chart
        <%
            // Compile labels and comment counts for chart
            const chartLabels = mostActiveTopics.map(t => t.title.substring(0, 15) + '...');
            const chartData = mostActiveTopics.map(t => t.comments.length);
        %>
        const topicsCtx = document.getElementById('activeTopicsChart').getContext('2d');
        new Chart(topicsCtx, {
            type: 'bar',
            data: {
                labels: <%- JSON.stringify(chartLabels) %>,
                datasets: [{
                    label: 'Comments Count',
                    data: <%- JSON.stringify(chartData) %>,
                    backgroundColor: 'rgba(0, 188, 212, 0.4)',
                    borderColor: '#00bcd4',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { color: '#94a3b8' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#94a3b8' }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Resident Activity Contributions Chart
        <%
            const residentLabels = mostActiveResidents.map(r => r.name);
            const residentData = mostActiveResidents.map(r => r.count);
        %>
        const resCtx = document.getElementById('activityChart').getContext('2d');
        new Chart(resCtx, {
            type: 'line',
            data: {
                labels: <%- JSON.stringify(residentLabels) %>,
                datasets: [{
                    label: 'Activity Posts / Comments',
                    data: <%- JSON.stringify(residentData) %>,
                    fill: true,
                    backgroundColor: 'rgba(224, 64, 251, 0.1)',
                    borderColor: '#e040fb',
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { color: '#94a3b8' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#94a3b8' }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    });
</script>

<%- include('partials/footer') %>
