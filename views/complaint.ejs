<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="row">
        <div class="col-md-12">
            <h2 style="color: #e91e63;"><i class="fas fa-headset"></i> Society Helpdesk Center</h2>
            <p class="text-muted">Open a ticket for plumbing, electrical, security, housekeeping, or lift failures.</p>
            <hr style="border-color: var(--border-glass);">
        </div>
    </div>

    <div class="row">
        <!-- Complaint Form -->
        <div class="col-md-7">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-file-invoice"></i> Support Request Form</h4></div>
                <div class="panel-body">
                    <form action="/complaint" method="POST" id="complaintForm">
                        <div class="form-group">
                            <label for="complaintDescription">Describe the Issue / Complaint Details:</label>
                            <textarea name="description" class="form-control" rows="6" id="complaintDescription" 
                                      placeholder="Example: The kitchen sink pipe is leaking water all over the floor..." required oninput="classifyComplaintText(this.value)"></textarea>
                        </div>

                        <!-- AI Suggestion Badge -->
                        <div id="aiClassificationSuggestion" style="margin-bottom: 20px; display: none;">
                            <div style="background: rgba(0, 188, 212, 0.1); border: 1px solid rgba(0, 188, 212, 0.3); border-radius: 8px; padding: 10px; display: flex; align-items: center; justify-content: space-between;">
                                <span><i class="fas fa-robot" style="color: #00bcd4;"></i> <strong>AI Classification:</strong> Auto-routing to department <strong id="suggestedDeptText" class="text-info">--</strong></span>
                                <span class="label label-info">Suggested</span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label for="complaintCategory">Department Category:</label>
                                    <select name="category" id="complaintCategory" class="form-control" required>
                                        <option value="Plumbing">Plumbing</option>
                                        <option value="Electrical">Electrical</option>
                                        <option value="Lift">Lift Operations</option>
                                        <option value="Security">Security Guard</option>
                                        <option value="Housekeeping">Housekeeping / Cleaning</option>
                                        <option value="Other">Other / General</option>
                                    </select> 
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Complaint Type Scope:</label>
                                    <div class="form-group" style="padding-top: 5px;">
                                        <label for="Personal" class="radio-inline" style="color: #fff; cursor:pointer;">
                                            <input type="radio" name="type" id="Personal" value="Personal" checked required> Personal Flat
                                        </label>
                                        <label for="Community" class="radio-inline" style="color: #fff; cursor:pointer;">
                                            <input type="radio" name="type" id="Community" value="Community" required> Common Society Area
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-danger"><i class="fas fa-paper-plane"></i> Submit Ticket</button>
                        <a href="/helpdesk" class="btn btn-secondary">Cancel</a>
                    </form>
                </div>
            </div>
        </div>

        <!-- AI Classifier Info Sidebar -->
        <div class="col-md-5">
            <div class="panel panel-default" style="border-left: 4px solid var(--accent-crimson) !important;">
                <div class="panel-heading"><h4><i class="fas fa-magic"></i> AI Smart Routing</h4></div>
                <div class="panel-body">
                    <p style="font-size: 13px; line-height: 1.5; color: var(--text-secondary);">
                        Our AI models analyze your description in real-time as you type and automatically route the request. This avoids delays by routing:
                    </p>
                    <ul style="font-size: 12px; line-height: 1.6; color: var(--text-secondary); margin-left: 15px;">
                        <li><strong>Plumbing:</strong> matches <code>leak</code>, <code>pipe</code>, <code>tap</code>, <code>clog</code>, <code>water</code></li>
                        <li><strong>Electrical:</strong> matches <code>fuse</code>, <code>spark</code>, <code>wire</code>, <code>light</code>, <code>power</code></li>
                        <li><strong>Lift:</strong> matches <code>elevator</code>, <code>lift</code>, <code>buttons</code></li>
                        <li><strong>Security:</strong> matches <code>guard</code>, <code>parking</code>, <code>gate</code>, <code>stranger</code></li>
                        <li><strong>Housekeeping:</strong> matches <code>garbage</code>, <code>trash</code>, <code>sweep</code>, <code>dirty</code>, <code>clean</code></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function classifyComplaintText(text) {
        const t = text.toLowerCase();
        let category = null;

        // Simple real-time classifier logic (mirrors backend classification)
        if (t.includes('leak') || t.includes('pipe') || t.includes('tap') || t.includes('clog') || t.includes('plumb')) {
            category = 'Plumbing';
        } else if (t.includes('fuse') || t.includes('spark') || t.includes('wire') || t.includes('light') || t.includes('power') || t.includes('electric')) {
            category = 'Electrical';
        } else if (t.includes('elevator') || t.includes('lift')) {
            category = 'Lift';
        } else if (t.includes('guard') || t.includes('parking') || t.includes('gate') || t.includes('stranger') || t.includes('security')) {
            category = 'Security';
        } else if (t.includes('garbage') || t.includes('trash') || t.includes('sweep') || t.includes('dirty') || t.includes('clean') || t.includes('housekeep')) {
            category = 'Housekeeping';
        }

        const suggestionBox = document.getElementById('aiClassificationSuggestion');
        const suggestedText = document.getElementById('suggestedDeptText');
        const categorySelect = document.getElementById('complaintCategory');

        if (category) {
            suggestedText.innerText = category;
            suggestionBox.style.display = 'block';
            
            // Auto-select in the select option
            for (let i = 0; i < categorySelect.options.length; i++) {
                if (categorySelect.options[i].value === category) {
                    categorySelect.selectedIndex = i;
                    break;
                }
            }
        } else {
            suggestionBox.style.display = 'none';
        }
    }
</script>

<%- include('partials/footer') %>