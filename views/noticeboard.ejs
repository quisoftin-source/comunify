<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <!-- Noticeboard Header -->
    <div class="row">
        <div class="col-sm-8">
            <h2 style="color: #ff9800; margin-top: 5px;"><i class="fas fa-bullhorn"></i> Society Noticeboard</h2>
            <p class="text-muted">Important circulars, AGM announcements, and general society notifications.</p>
        </div>
        <div class="col-sm-4 text-right">
            <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <a href="/notice" class="btn btn-primary" style="margin-top: 5px;">
                    <i class="fas fa-plus-circle"></i> Create New Notice
                </a>
            <% } %>
        </div>
    </div>
    
    <hr style="border-color: var(--border-glass);">

    <!-- Pending Maintenance Highlight Panel -->
    <% if (locals.pendingResidents && pendingResidents.length > 0) { %>
        <div class="row" style="margin-bottom: 25px;">
            <div class="col-md-12">
                <div class="panel panel-danger" style="border: 2px solid #f44336; box-shadow: 0 0 15px rgba(244, 67, 54, 0.4); background: rgba(244, 67, 54, 0.05) !important;">
                    <div class="panel-heading" style="background-color: #f44336; color: white; display: flex; justify-content: space-between; align-items: center; padding: 12px 15px;">
                        <h4 class="panel-title" style="font-weight: bold; font-size: 16px; margin: 0;">
                            <i class="fas fa-exclamation-triangle animate-pulse" style="margin-right: 8px;"></i>
                            CRITICAL NOTICE: PENDING MAINTENANCE DEFAULTERS
                        </h4>
                        <span class="label label-default" style="font-size: 11px; font-weight: bold;">ACTION REQUIRED</span>
                    </div>
                    <div class="panel-body" style="padding: 15px;">
                        <p class="text-muted" style="font-size: 13px; color: #ffcdd2 !important; margin-bottom: 15px;">
                            The following residents have pending maintenance invoices. Please clear your dues immediately to avoid late payment penalties and suspension of non-essential common facilities.
                        </p>
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped" style="margin-bottom: 0; font-size: 13px; color: #fff; background: rgba(0,0,0,0.2);">
                                <thead>
                                    <tr style="background: rgba(244, 67, 54, 0.2); color: #ffcdd2;">
                                        <th>Resident Name</th>
                                        <th>Flat No. / Tower</th>
                                        <th>Contact Number</th>
                                        <th>Outstanding Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% pendingResidents.forEach(function(resident) { %>
                                        <tr>
                                            <td style="font-weight: bold;"><%= resident.firstName %> <%= resident.lastName %></td>
                                            <td><span class="label label-danger">Unit <%= resident.flatNumber %></span></td>
                                            <td><i class="fas fa-phone-alt" style="margin-right: 5px; color: #ffcdd2;"></i> <%= resident.phoneNumber %></td>
                                            <td style="font-weight: bold; color: #ff5252;"><%= formatINR(resident.makePayment) %></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% } %>

    <!-- Notices Listing Grid -->
    <div class="row">
        <div class="col-md-12">
            <% if (notices && notices.length > 0) { %>
                <% notices.slice().reverse().forEach(function(notice) { %>
                    <div class="panel panel-default">
                        <div class="panel-body">
                            <h4 style="font-weight: bold; color: #fff; margin-bottom: 8px;">
                                <i class="fas fa-thumbtack" style="color: #ff9800; margin-right: 8px;"></i>
                                <%= notice.subject %>
                            </h4>
                            <p style="font-size: 12px; color: var(--text-secondary); margin-bottom: 15px;">
                                <i class="far fa-calendar-alt"></i> Published: <strong><%= notice.date %></strong> | Author: <strong>Management Office</strong>
                            </p>
                            <p style="font-size: 14px; line-height: 1.6; white-space: pre-line; color: var(--text-primary);">
                                <%= notice.details %>
                            </p>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="panel panel-default">
                    <div class="panel-body text-center" style="padding: 50px 0;">
                        <i class="far fa-sticky-note" style="font-size: 5rem; color: var(--text-secondary); opacity: 0.3; margin-bottom: 15px;"></i>
                        <p class="text-muted">No announcement notices posted at this time.</p>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>