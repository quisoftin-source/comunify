<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <h2 style="color: #ff9800;"><i class="fas fa-user-shield"></i> Admin Workspace</h2>
    <p>Manage your society, review resident requests, and export data.</p>
    <hr style="border-color: var(--border-glass);">

    <% if (!isCurrentActiveAGM) { %>
        <div class="row">
            <div class="col-md-12">
                <div class="panel panel-warning" style="background: rgba(245, 175, 25, 0.05) !important;">
                    <div class="panel-heading"><h4><i class="fas fa-exclamation-triangle"></i> Administrative Actions Restricted</h4></div>
                    <div class="panel-body text-center" style="padding: 30px !important;">
                        <p class="lead" style="color: #fff;">Approvals and core settings can only be managed by the active designated Society AGM.</p>
                        <p class="text-muted" style="font-size: 15px;">Active Approving AGM Email: <strong style="color: var(--accent-orange);"><%= activeAGMEmail || 'No active AGM set' %></strong></p>
                        <p style="margin-top: 15px;">If you have resigned or been replaced, you no longer possess approval permissions. For assistance, contact the Platform IT Admin.</p>
                    </div>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="row">
            <!-- Quick Links -->
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-tasks"></i> Core Modules</h4></div>
                    <div class="panel-body">
                        <a href="/noticeboard" class="btn btn-primary btn-block" style="margin-bottom: 10px;">
                            <i class="fas fa-bullhorn"></i> Manage Notice Board
                        </a>
                        <a href="/editBill" class="btn btn-info btn-block" style="margin-bottom: 10px;">
                            <i class="fas fa-file-invoice-dollar"></i> Configure Billing/Bills
                        </a>
                        <a href="/editContacts" class="btn btn-warning btn-block">
                            <i class="fas fa-address-book"></i> Edit Emergency Contacts
                        </a>
                    </div>
                </div>
            </div>

            <!-- Data Export -->
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-download"></i> Data Export (Dumps)</h4></div>
                    <div class="panel-body">
                        <p>Export datasets to CSV format for external reporting.</p>
                        <a href="/admin/export/members" class="btn btn-success btn-block" style="margin-bottom: 10px;">
                            <i class="fas fa-users"></i> Export Member List
                        </a>
                        <a href="/admin/export/expenses" class="btn btn-success btn-block" style="margin-bottom: 10px;">
                            <i class="fas fa-chart-line"></i> Export Maintenance Settings (Expense Report)
                        </a>
                        <a href="/admin/export/maintenance" class="btn btn-success btn-block">
                            <i class="fas fa-tools"></i> Export Maintenance Logs (Helpdesk)
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- In-App Request Manager -->
            <div class="col-md-12">
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-user-clock"></i> In-App Request Manager (Resident Approvals)</h4></div>
                    <div class="panel-body">
                        <% if (pendingResidents && pendingResidents.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Flat Number</th>
                                            <th>Phone</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% pendingResidents.forEach(function(resident) { %>
                                            <tr>
                                                <td><%= resident.firstName %> <%= resident.lastName %></td>
                                                <td><%= resident.flatNumber %></td>
                                                <td><%= resident.phoneNumber %></td>
                                                <td>
                                                    <form action="/approveResident" method="POST" style="display:inline;">
                                                        <input type="hidden" name="validate[<%= resident._id %>]" value="approved">
                                                        <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-check"></i> Approve</button>
                                                    </form>
                                                    <form action="/rejectResident" method="POST" style="display:inline;">
                                                        <input type="hidden" name="userId" value="<%= resident._id %>">
                                                        <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-times"></i> Reject</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted">No pending resident requests at this time.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- AGM Resignation and Succession Panel -->
        <div class="row">
            <div class="col-md-12">
                <div class="panel panel-danger" style="border-color: #ff416c !important;">
                    <div class="panel-heading" style="background: rgba(255, 65, 108, 0.05) !important; color: #ff416c !important;">
                        <h4><i class="fas fa-user-minus"></i> Resign & Delegate AGM Role</h4>
                    </div>
                    <div class="panel-body" style="padding: 20px !important;">
                        <p class="text-danger" style="font-weight: 500; font-size: 14px;">
                            <i class="fas fa-exclamation-triangle"></i> WARNING: Resigning will transfer all member approval and billing setup rights to the designated successor. Your account role will be downgraded to a normal Member (Resident).
                        </p>
                        <form action="/admin/resign" method="POST" class="form-inline" style="display: flex; gap: 15px; align-items: center; flex-wrap: wrap; margin-top: 15px;">
                            <div class="form-group" style="margin-bottom: 0;">
                                <label for="successorEmail" style="margin-right: 10px; color: var(--text-secondary);">Select Successor AGM:</label>
                                <select name="successorEmail" id="successorEmail" class="form-control" required style="width: 280px;">
                                    <option value="" disabled selected>Select an approved member</option>
                                    <% residents.forEach(function(r) { %>
                                        <% if (r.username !== user.username) { %>
                                            <option value="<%= r.username %>"><%= r.firstName %> <%= r.lastName %> (<%= r.flatNumber %>) - <%= r.username %></option>
                                        <% } %>
                                    <% }); %>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to resign and delegate approval rights? This action is immediate and will log you out.');" style="padding: 10px 20px;">
                                <i class="fas fa-sign-out-alt"></i> Resign & Delegate Successor
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    <% } %>

    <div class="row">
        <div class="col-md-12 text-center" style="margin-top: 20px; color: var(--text-secondary); margin-bottom: 20px;">
            <small>Comunify Management Workspace | Developers By- quisoft.in</small>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
