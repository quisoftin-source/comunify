<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="row">
        <!-- Configure baseline pricing (original form) -->
        <div class="col-md-5">
            <div class="panel panel-default">
                <div class="panel-heading text-center">
                    <h4><i class="fas fa-cogs"></i> Base Maintenance Config</h4>
                </div>
                <div class="panel-body">
                    <form class="form-edit" action="/editBill" method="POST">
                        <div class="form-group">
                            <label for="societyCharges">Society Common Charges (₹):</label>
                            <input name="societyCharges" type="number" id="societyCharges" class="form-control" value="<%= maintenanceBill.societyCharges %>" required>
                        </div>
                        <div class="form-group">
                            <label for="sinkingFund">Sinking Fund Contribution (₹):</label>
                            <input name="sinkingFund" type="number" id="sinkingFund" class="form-control" value="<%= maintenanceBill.sinkingFund %>" required>
                        </div>
                        <div class="form-group">
                            <label for="waterCharges">Base Water Charges (₹):</label>
                            <input name="waterCharges" type="number" id="waterCharges" class="form-control" value="<%= maintenanceBill.waterCharges %>" required>
                        </div>
                        <div class="form-group">
                            <label for="repairsAndMaintenance">Electricity & Common Power Repairs (₹):</label>
                            <input name="repairsAndMaintenance" type="number" id="repairsAndMaintenance" class="form-control" value="<%= maintenanceBill.repairsAndMaintenance %>" required>
                        </div>
                        <div class="form-group">
                            <label for="insuranceCharges">Common Insurance Cover (₹):</label>
                            <input name="insuranceCharges" type="number" id="insuranceCharges" class="form-control" value="<%= maintenanceBill.insuranceCharges %>" required>
                        </div>
                        <div class="form-group">
                            <label for="parkingCharges">Parking Space Charges (₹):</label>
                            <input name="parkingCharges" type="number" id="parkingCharges" class="form-control" value="<%= maintenanceBill.parkingCharges %>" required>
                        </div>
                        
                        <div style="margin-top: 25px;">
                            <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-check"></i> Save Base Settings</button>
                            <a href="/bill" class="btn btn-secondary btn-block">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Add Dynamic Bill Form -->
        <div class="col-md-7">
            <div class="panel panel-default" style="border-left: 4px solid #4caf50 !important;">
                <div class="panel-heading text-center">
                    <h4><i class="fas fa-file-invoice-dollar"></i> Add New Dynamic Bill / Charge</h4>
                </div>
                <div class="panel-body">
                    <form action="/bill/add" method="POST" enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="billTitle">Bill Particulars / Name:</label>
                            <input name="title" type="text" id="billTitle" class="form-control" placeholder="e.g. Electrical Work, Lift Repair, Civil Work" required>
                        </div>
                        <div class="row">
                            <div class="col-xs-6">
                                <div class="form-group">
                                    <label for="billAmount">Amount (₹):</label>
                                    <input name="amount" type="number" id="billAmount" class="form-control" placeholder="Dues Amount" required>
                                </div>
                            </div>
                            <div class="col-xs-6">
                                <div class="form-group">
                                    <label for="targetFlat">Target Flat Unit:</label>
                                    <select name="targetFlat" id="targetFlat" class="form-control" required>
                                        <option value="All">All Society Flats</option>
                                        <% residents.forEach(function(res) { %>
                                            <option value="<%= res.flatNumber %>">Flat <%= res.flatNumber %> (<%= res.firstName %> <%= res.lastName %>)</option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-xs-6">
                                <div class="form-group">
                                    <label for="billMonth">Billing Month:</label>
                                    <select name="month" id="billMonth" class="form-control" required>
                                        <option value="January">January</option>
                                        <option value="February">February</option>
                                        <option value="March">March</option>
                                        <option value="April">April</option>
                                        <option value="May">May</option>
                                        <option value="June">June</option>
                                        <option value="July">July</option>
                                        <option value="August">August</option>
                                        <option value="September">September</option>
                                        <option value="October">October</option>
                                        <option value="November">November</option>
                                        <option value="December">December</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-xs-6">
                                <div class="form-group">
                                    <label for="billYear">Billing Year:</label>
                                    <input name="year" type="number" id="billYear" class="form-control" value="<%= new Date().getFullYear() %>" required>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="billAttachment">Attachment Receipt (PDF / Image):</label>
                            <input name="attachment" type="file" id="billAttachment" class="form-control" accept=".pdf,image/*">
                        </div>
                        
                        <button type="submit" class="btn btn-success btn-block" style="margin-top: 15px;"><i class="fas fa-plus-circle"></i> Issue Bill</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Bills List -->
    <div class="row" style="margin-top: 20px;">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-list-ul"></i> Issued Dynamic Bills Log</h4></div>
                <div class="panel-body">
                    <% if (locals.bills && bills.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle" style="font-size: 13px;">
                                <thead>
                                    <tr>
                                        <th>Date Issued</th>
                                        <th>Title</th>
                                        <th>Target</th>
                                        <th>Billing Month</th>
                                        <th>Attachment</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% bills.slice().reverse().forEach(function(b) { %>
                                        <tr>
                                            <td><%= new Date(b.createdAt).toLocaleDateString() %></td>
                                            <td><strong><%= b.title %></strong></td>
                                            <td><span class="label <%= b.targetFlat === 'All' ? 'label-success' : 'label-info' %>"><%= b.targetFlat === 'All' ? 'ALL FLATS' : 'Flat ' + b.targetFlat %></span></td>
                                            <td><%= b.month %> <%= b.year %></td>
                                            <td>
                                                <% if (b.attachmentPath) { %>
                                                    <a href="<%= b.attachmentPath %>" target="_blank" class="btn btn-danger btn-xs"><i class="fas fa-file-pdf"></i> View attachment</a>
                                                <% } else { %>
                                                    <span class="text-muted" style="font-size: 11px;">None</span>
                                                <% } %>
                                            </td>
                                            <td style="font-weight: bold; color: var(--accent-cyan);">₹ <%= b.amount %></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 15px;">No dynamic bills issued yet.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>