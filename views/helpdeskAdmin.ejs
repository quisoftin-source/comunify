<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <!-- Title & Ticket Create Option -->
    <div class="row">
        <div class="col-sm-8">
            <h2 style="color: #ff9800; margin-top: 5px;"><i class="fas fa-tools"></i> Society Helpdesk Center</h2>
            <p class="text-muted">Review resident complaints, assign task orders to internal staff, and log resolutions.</p>
        </div>
        <div class="col-sm-4 text-right">
            <a href="/complaint" class="btn btn-warning" style="margin-top: 5px;">
                <i class="fas fa-plus-circle"></i> Create Support Ticket
            </a>
        </div>
    </div>
    
    <hr style="border-color: var(--border-glass);">

    <!-- Configure Helpdesk Team Details Form -->
    <div class="row" style="margin-bottom: 25px;">
        <div class="col-md-12">
            <div class="panel panel-default" style="border-left: 4px solid #ff9800 !important;">
                <div class="panel-heading"><h4><i class="fas fa-cogs"></i> Configure Helpdesk Team Settings</h4></div>
                <div class="panel-body">
                    <form action="/admin/helpdesk/settings" method="POST" class="form-inline" style="display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
                        <div class="form-group">
                            <label for="helpdeskName" style="margin-right: 5px;">Helpdesk Team Name:</label>
                            <input name="helpdeskName" type="text" id="helpdeskName" class="form-control" value="<%= society.helpdeskName || 'Resident Care Desk' %>" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
                        </div>
                        <div class="form-group">
                            <label for="helpdeskPhone" style="margin-right: 5px;">Contact Phone Number:</label>
                            <input name="helpdeskPhone" type="text" id="helpdeskPhone" class="form-control" value="<%= society.helpdeskPhone || '080-12345678' %>" required style="background: rgba(0,0,0,0.2); color: #fff; border: 1px solid var(--border-glass);">
                        </div>
                        <button type="submit" class="btn btn-warning"><i class="fas fa-save"></i> Save Settings</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Tickets Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-clipboard-list"></i> Open Support Tickets Queue</h4></div>
                <div class="panel-body">
                    <% if (users && users.length > 0) { %>
                        <% 
                            // Accumulate all complaints with their originating user info
                            const allTickets = [];
                            users.forEach(function(u) {
                                if (u.complaints && u.complaints.length > 0) {
                                    u.complaints.forEach(function(c, index) {
                                        if (c.category !== 'You have not raised any complaint') {
                                            allTickets.push({
                                                userId: u._id,
                                                userName: u.firstName + ' ' + u.lastName,
                                                flatNumber: u.flatNumber,
                                                ticketIndex: index,
                                                date: c.date,
                                                category: c.category,
                                                type: c.type,
                                                description: c.description,
                                                status: c.status || 'open',
                                                assignedStaff: c.assignedStaff || ''
                                            });
                                        }
                                    });
                                }
                            });
                            // Sort by status (open, in-progress first) then date
                            allTickets.sort((a,b) => {
                                if (a.status === 'open' && b.status !== 'open') return -1;
                                if (a.status !== 'open' && b.status === 'open') return 1;
                                return new Date(b.date) - new Date(a.date);
                            });
                        %>

                        <% if (allTickets.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-striped table-hover align-middle" style="font-size: 13px;">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Resident / Flat</th>
                                            <th>Department</th>
                                            <th>Scope</th>
                                            <th>Description Details</th>
                                            <th>Assigned Staff</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% allTickets.forEach(function(t) { %>
                                            <tr>
                                                <td><%= t.date %></td>
                                                <td>
                                                    <strong><%= t.userName %></strong><br>
                                                    <span class="label label-danger">Flat <%= t.flatNumber %></span>
                                                </td>
                                                <td><strong><%= t.category %></strong></td>
                                                <td>
                                                    <span class="label <%= t.type === 'Personal' ? 'label-info' : 'label-warning' %>"><%= t.type %></span>
                                                </td>
                                                <td><%= t.description %></td>
                                                <td>
                                                    <form action="/admin/complaint/assign" method="POST" class="form-inline">
                                                        <input type="hidden" name="userId" value="<%= t.userId %>">
                                                        <input type="hidden" name="ticketIndex" value="<%= t.ticketIndex %>">
                                                        <select name="assignedStaff" class="form-control input-xs" onchange="this.form.submit()" <%= t.status === 'close' ? 'disabled' : '' %> style="background: rgba(255,255,255,0.05); font-size:11px; padding: 2px;">
                                                            <option value="">Select Staff</option>
                                                            <option value="Ramesh (Plumber)" <%= t.assignedStaff === 'Ramesh (Plumber)' ? 'selected' : '' %>>Ramesh (Plumber)</option>
                                                            <option value="Suresh (Electrician)" <%= t.assignedStaff === 'Suresh (Electrician)' ? 'selected' : '' %>>Suresh (Electrician)</option>
                                                            <option value="Kamlesh (Gardener)" <%= t.assignedStaff === 'Kamlesh (Gardener)' ? 'selected' : '' %>>Kamlesh (Gardener)</option>
                                                            <option value="Gate Guards desk" <%= t.assignedStaff === 'Gate Guards desk' ? 'selected' : '' %>>Gate Guards desk</option>
                                                            <option value="Housekeeping Unit" <%= t.assignedStaff === 'Housekeeping Unit' ? 'selected' : '' %>>Housekeeping Unit</option>
                                                        </select>
                                                    </form>
                                                </td>
                                                <td>
                                                    <span class="label <%= t.status === 'open' ? 'label-danger' : t.status === 'in-progress' ? 'label-warning' : 'label-success' %>">
                                                        <%= t.status.toUpperCase() %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <% if (t.status !== 'close') { %>
                                                        <form action="/closeTicket" method="POST" style="display:inline;">
                                                            <input type="hidden" name="ticket[<%= t.userId %>]" value="<%= t.ticketIndex %>">
                                                            <button type="submit" class="btn btn-success btn-xs"><i class="fas fa-check-double"></i> Close Ticket</button>
                                                        </form>
                                                    <% } else { %>
                                                        <span class="text-muted"><i class="fas fa-check"></i> Resolved</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted text-center" style="padding: 20px;">All resident tickets are resolved and closed!</p>
                        <% } %>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 20px;">No registered residents in the database.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>