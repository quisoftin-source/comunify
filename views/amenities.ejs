<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="row">
        <div class="col-md-12">
            <h2 style="color: #ff9800;"><i class="fas fa-calendar-check"></i> Amenity Booking System</h2>
            <p class="text-muted">Reserve common facilities like the Clubhouse, Party Hall, Gym, and Sports Courts instantly.</p>
            <hr style="border-color: var(--border-glass);">
        </div>
    </div>

    <!-- Main Booking Section -->
    <div class="row">
        <!-- Booking form & Catalog -->
        <div class="col-md-7">
            <!-- Amenities Catalog -->
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-dumbbell"></i> Available Amenities</h4></div>
                <div class="panel-body">
                    <div class="row">
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-home" style="font-size: 3rem; color: #ff9800; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Clubhouse</h5>
                                <small class="text-muted">Capacity: 50 pax</small>
                            </div>
                        </div>
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-swimmer" style="font-size: 3rem; color: #00bcd4; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Swimming Pool</h5>
                                <small class="text-muted">Capacity: 20 pax</small>
                            </div>
                        </div>
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-glass-cheers" style="font-size: 3rem; color: #e91e63; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Party Hall</h5>
                                <small class="text-muted">Capacity: 150 pax</small>
                            </div>
                        </div>
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-table-tennis" style="font-size: 3rem; color: #4caf50; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Sports Court</h5>
                                <small class="text-muted">Capacity: 8 pax</small>
                            </div>
                        </div>
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-tree" style="font-size: 3rem; color: #8bc34a; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Garden</h5>
                                <small class="text-muted">Capacity: 100 pax</small>
                            </div>
                        </div>
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-parking" style="font-size: 3rem; color: #2196f3; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Parking Space</h5>
                                <small class="text-muted">Capacity: 1 slot</small>
                            </div>
                        </div>
                        <div class="col-xs-6" style="margin-bottom: 15px;">
                            <div style="border: 1px solid var(--border-glass); border-radius: 8px; padding: 15px; text-align: center;">
                                <i class="fas fa-warehouse" style="font-size: 3rem; color: #9e9e9e; margin-bottom: 8px;"></i>
                                <h5 style="font-weight: bold; color: #fff;">Basement</h5>
                                <small class="text-muted">Capacity: 5 pax</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Booking Form -->
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-calendar-plus"></i> Request Booking Slot</h4></div>
                <div class="panel-body">
                    <form action="/amenities/book" method="POST">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Select Facility:</label>
                                    <select name="amenityName" class="form-control" required>
                                        <option value="Clubhouse">Clubhouse</option>
                                        <option value="Swimming Pool">Swimming Pool</option>
                                        <option value="Party Hall">Party Hall</option>
                                        <option value="Sports Court">Sports Court</option>
                                        <option value="Garden">Garden</option>
                                        <option value="Parking Space">Parking Space</option>
                                        <option value="Basement">Basement</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Date of Booking:</label>
                                    <input type="date" name="date" class="form-control" required id="bookingDateInput">
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Preferred Time Slot:</label>
                            <select name="slot" class="form-control" required>
                                <option value="06:00 AM - 09:00 AM">Morning Slot (06:00 AM - 09:00 AM)</option>
                                <option value="09:00 AM - 12:00 PM">Late Morning Slot (09:00 AM - 12:00 PM)</option>
                                <option value="01:00 PM - 04:00 PM">Afternoon Slot (01:00 PM - 04:00 PM)</option>
                                <option value="05:00 PM - 08:00 PM">Evening Slot (05:00 PM - 08:00 PM)</option>
                                <option value="08:00 PM - 11:00 PM">Night Slot (08:00 PM - 11:00 PM)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-ticket-alt"></i> Confirm Slot Booking</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- My Bookings Summary Sidebar -->
        <div class="col-md-5">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-history"></i> My Active Bookings</h4></div>
                <div class="panel-body">
                    <% if (myBookings.length > 0) { %>
                        <% myBookings.forEach(function(b) { %>
                            <div style="border-bottom: 1px solid var(--border-glass); padding-bottom: 10px; margin-bottom: 10px;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <strong style="color: #fff;"><%= b.amenityName %></strong>
                                    <form action="/amenities/cancel" method="POST">
                                        <input type="hidden" name="bookingId" value="<%= b._id %>">
                                        <button type="submit" class="btn btn-danger btn-xs"><i class="fas fa-times"></i> Cancel</button>
                                    </form>
                                </div>
                                <p class="text-muted" style="margin-bottom: 0; font-size: 13px;">
                                    Date: <strong><%= b.date %></strong> | Slot: <strong><%= b.slot %></strong>
                                </p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 15px;">You have no active amenity bookings.</p>
                    <% } %>
                </div>
            </div>

            <!-- Global Bookings Calendar Tracker for Society Admin -->
            <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <div class="panel panel-default" style="border-left: 4px solid #ff9800 !important;">
                    <div class="panel-heading"><h4><i class="fas fa-users-cog"></i> Society Facility Usage Log</h4></div>
                    <div class="panel-body">
                        <% if (allBookings && allBookings.length > 0) { %>
                            <div style="max-height: 200px; overflow-y: auto;">
                                <table class="table table-striped" style="font-size: 12px;">
                                    <thead>
                                        <tr>
                                            <th>Resident</th>
                                            <th>Flat</th>
                                            <th>Facility</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% allBookings.forEach(function(ab) { %>
                                            <tr>
                                                <td><%= ab.userName %></td>
                                                <td><%= ab.flatNumber %></td>
                                                <td><strong><%= ab.amenityName %></strong></td>
                                                <td><%= ab.date %></td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <p class="text-muted text-center">No bookings registered for society facilities.</p>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    // Set min date of datepicker to today
    document.addEventListener("DOMContentLoaded", function() {
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('bookingDateInput').setAttribute('min', today);
    });
</script>

<%- include('partials/footer') %>
