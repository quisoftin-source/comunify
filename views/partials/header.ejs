<!-- Header content -->
<!DOCTYPE html>
<html lang="en">

<head>
  <title>Comunify</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
  <meta name="description" content="SaaS multi-tenant community management system.">
  <link rel="icon" type="image/png" href="/images/comunify_logo.png" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/styles.css">
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="pdf-generator.js"></script>
  <style>
    .blink-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      background-color: #ef4444; /* bright red */
      border-radius: 50%;
      margin-left: 5px;
      vertical-align: middle;
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
      animation: pulse-dot 1.2s infinite;
    }
    @keyframes pulse-dot {
      0% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
      }
      70% {
        transform: scale(1);
        box-shadow: 0 0 0 6px rgba(239, 68, 68, 0);
      }
      100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
      }
    }
  </style>
</head>

<body>
  <nav class="navbar navbar-inverse">
    <div class="container-fluid" id="navbar">
      <div class="navbar-header">
        <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#myNavbar">
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>                        
        </button>
        <a class="navbar-brand" href="/home">
          <img src="/images/comunify_logo.png" alt="Comunify" onerror="this.src='https://cdn-icons-png.flaticon.com/512/900/900263.png'">
        </a>
      </div>
      <div class="collapse navbar-collapse" id="myNavbar">
        <ul class="nav navbar-nav" id="navlist">
          <% if (locals.user) { %>
            <% if (user.role === 'super_admin') { %>
              <li><a href="/home"><i class="fas fa-arrow-left"></i> Home</a></li>
              <li><a href="/superadmin" style="color: #ec407a; font-weight: bold;"><i class="fas fa-user-shield"></i> Super Admin Portal</a></li>
              <li><a href="/register" style="color: #00bcd4;"><i class="fas fa-plus-circle"></i> Register Society</a></li>
            <% } else if (user.role === 'security_guard') { %>
              <li><a href="/home"><i class="fas fa-arrow-left"></i> Home</a></li>
              <li><a href="/guard" style="color: #4caf50; font-weight: bold;"><i class="fas fa-shield-alt"></i> Guard Dashboard</a></li>
              <li><a href="/contacts">Emergency Contacts</a></li>
            <% } else { %>
              <li><a href="/home"><i class="fas fa-arrow-left"></i> Home</a></li>
              <li><a href="/residents">Residents</a></li>
              <li><a href="/noticeboard">Noticeboard</a></li>
              <li><a href="/bill">Bill</a></li>
              <li><a href="/helpdesk">Helpdesk</a></li>
              <li><a href="/amenities">Amenities</a></li>
              <li><a href="/community-hub"><i class="fas fa-users-cog"></i> Community Hub<% if (locals.hasNewMarketplacePost) { %><span class="blink-dot"></span><% } %></a></li>
              <li><a href="/documents">Documents</a></li>
              <li><a href="/cctv">CCTV Live</a></li>
              <li><a href="/marketplace">Marketplace<% if (locals.hasNewMarketplacePost) { %><span class="blink-dot"></span><% } %></a></li>
              <li><a href="/contacts">Emergency</a></li>
              <li><a href="/profile">Profile</a></li>
              <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <li><a href="/admin" style="color: #ff9800; font-weight: bold;"><i class="fas fa-cogs"></i> Society Workspace</a></li>
              <% } %>
            <% } %>
          <% } else { %>
            <li><a href="/">Home</a></li>
            <li><a href="/#deck">Features</a></li>
            <li><a href="/#stats">Demographics</a></li>
          <% } %>
        </ul>
        <ul class="nav navbar-nav navbar-right">
          <% if (locals.user) { %>
            <li class="navbar-text" style="color: #94a3b8; margin-right: 15px; padding-top: 5px;">
              <span class="badge badge-role <%= user.role === 'super_admin' ? 'badge-super' : user.role === 'society_admin' ? 'badge-admin' : user.role === 'security_guard' ? 'badge-guard' : user.role === 'committee_member' ? 'badge-committee' : 'badge-resident' %>">
                <%= user.role.replace('_', ' ') %>
              </span>
              <% if (user.role === 'super_admin') { %>
                <%= user.firstName %> <%= user.lastName %>
              <% } else { %>
                <%= user.firstName %> (<%= user.societyName || 'System' %>)
              <% } %>
            </li>
            <li><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
          <% } else { %>
            <li><a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <% if (locals.user) { %>
    <div class="container back-to-dashboard-container" style="margin-top: 15px; margin-bottom: -15px; display: none;">
      <a href="/home" class="btn btn-default btn-sm" style="background: rgba(255, 255, 255, 0.05); color: #94a3b8; border: 1px solid var(--border-glass);">
        <i class="fas fa-chevron-left"></i> Back to Dashboard
      </a>
    </div>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        var path = window.location.pathname;
        if (path !== "/home" && path !== "/superadmin" && path !== "/guard" && path !== "/") {
          var container = document.querySelector(".back-to-dashboard-container");
          if (container) container.style.display = "block";
        }
      });
    </script>
  <% } %>