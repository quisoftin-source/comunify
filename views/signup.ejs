<!-- Member signup form -->
<%- include('partials/headerForm') %>

  <body>
    <div class="container">
      <div class="row">
        <div class="col-sm-9 col-md-7 col-lg-5 mx-auto">
          <div class="card card-signin my-5">
            <div class="card-body">
              <div class="text-center" style="margin-bottom: 20px;">
                <img src="/images/comunify_logo.png" alt="Comunify Logo" style="height: 60px; filter: drop-shadow(0 0 6px rgba(0, 188, 212, 0.35));">
              </div>
              <h5 class="card-title text-center" style="margin-top: 0; margin-bottom: 20px;">Sign-up</h5>
              <form class="form-signin" action="/signup" method="POST">
                <div class="form-label-group">
                  <input name="firstName" type="text" id="inputFirstName" class="form-control" placeholder="First name " required autofocus>
                  <label for="inputFirstName">First name</label>
                </div>
                <div class="form-label-group">
                  <input name="lastName" type="text" id="inputLastName" class="form-control" placeholder="Last name " required >
                  <label for="inputLastName">Last name</label>
                </div>
                <div class="form-label-group">
                  <input name="phoneNumber" type="text" id="inputPhoneNumber" class="form-control" placeholder="Phone number" required>
                  <label for="inputPhoneNumber">Phone number</label>
                </div>
                <div class="form-group mb-3">
                  <label for="inputSocietyName" class="text-muted" style="font-size: 13px; margin-left: 10px;">Select Housing Society</label>
                  <select name="societyName" id="inputSocietyName" class="form-control" required style="height: 50px; border-radius: 2rem; padding: 0 1.5rem; font-size: 14px; border: 1px solid #ced4da;">
                    <option value="" disabled selected>Select Society</option>
                    <% societies.forEach(society => { %>
                      <option value="<%= society.societyName %>"><%= society.societyName %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-label-group">
                  <input name="flatNumber" type="text" id="inputFlatNumber" class="form-control" placeholder="Flat number" required>
                  <label for="inputFlatNumber">Flat number</label>
                </div>
                <div class="form-label-group">
                  <input name="username" type="email" id="email" class="form-control" placeholder="Email" required>
                  <label for="email">Email</label>
                </div>
                <div class="form-label-group">
                  <input name="password" type="password" id="inputPassword" class="form-control" placeholder="Password" required>
                  <label for="inputPassword">Password</label>
                </div>
                <button class="btn btn-lg btn-dark btn-block text-uppercase" type="submit" style="font-size:15px;">Sign up</button>
                <hr class="my-4">
                <h6 class="card-text text-center">Already have an account? </h6></b>
                <a href="/login" class="btn  btn-danger btn-block text-uppercase" type="submit" style="font-size:15px;">sign-in</a>
                <a href="/" class="btn  btn-secondary btn-block text-uppercase">Home</a>
                <p class="text-center text-muted" style="font-size: 12px; margin-top: 15px; color: var(--text-secondary) !important;">Developers By- quisoft.in</p>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
  
</html>