<%- include('partials/header') %>

<div class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="row">
        <div class="col-md-12">
            <h2 style="color: #ff9800;"><i class="fas fa-truck-loading"></i> Vendor & AMC Contracts Registry</h2>
            <p class="text-muted">Manage external vendor contracts, Annual Maintenance Contracts (AMC), and payments.</p>
            <hr style="border-color: var(--border-glass);">
        </div>
    </div>

    <div class="row">
        <!-- Vendors Contracts List -->
        <div class="col-md-8">
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-file-contract"></i> Active AMC Contracts</h4></div>
                <div class="panel-body">
                    <% if (vendors && vendors.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Vendor / Service</th>
                                        <th>Contact Person</th>
                                        <th>AMC Period</th>
                                        <th>Value</th>
                                        <th>Rating</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% vendors.forEach(function(vendor) { %>
                                        <tr>
                                            <td>
                                                <strong><%= vendor.name %></strong><br>
                                                <small class="text-muted">Service: <%= vendor.serviceType %></small>
                                            </td>
                                            <td>
                                                <%= vendor.contactPerson %><br>
                                                <small class="text-muted"><%= vendor.phoneNumber %></small>
                                            </td>
                                            <td>
                                                <small>
                                                    Start: <%= new Date(vendor.amcStartDate).toLocaleDateString() %><br>
                                                    Expiry: <%= new Date(vendor.amcEndDate).toLocaleDateString() %>
                                                </small>
                                            </td>
                                            <td><strong><%= formatINR(vendor.contractValue) %></strong></td>
                                            <td style="color: #ff9800;">
                                                <i class="fas fa-star"></i> 
                                                <%= vendor.ratings.length > 0 ? (vendor.ratings.reduce((sum, r) => sum + r.rating, 0) / vendor.ratings.length).toFixed(1) : '5.0' %>
                                            </td>
                                            <td>
                                                <% if (user.role === 'society_admin') { %>
                                                    <form action="/vendors/delete" method="POST" style="display:inline;">
                                                        <input type="hidden" name="vendorId" value="<%= vendor._id %>">
                                                        <button type="submit" class="btn btn-danger btn-xs"><i class="fas fa-trash-alt"></i> Delete</button>
                                                    </form>
                                                <% } else { %>
                                                    <span class="text-muted">No Actions</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center" style="padding: 20px;">No vendor AMC contracts registered in this society.</p>
                    <% } %>
                </div>
            </div>
            
            <!-- Vendor Payments Logs -->
            <div class="panel panel-default">
                <div class="panel-heading"><h4><i class="fas fa-history"></i> Recent Vendor Contract Payments</h4></div>
                <div class="panel-body">
                    <% 
                        // Collect all payments from all vendors
                        const payments = [];
                        vendors.forEach(v => {
                            v.payments.forEach(p => {
                                payments.push({
                                    vendorName: v.name,
                                    service: v.serviceType,
                                    date: p.date,
                                    amount: p.amount,
                                    status: p.status,
                                    receipt: p.receipt
                                });
                            });
                        });
                        payments.sort((a,b) => new Date(b.date) - new Date(a.date));
                    %>
                    <% if (payments.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped" style="font-size: 13px;">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Vendor Name</th>
                                        <th>Service</th>
                                        <th>Paid Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% payments.forEach(function(p) { %>
                                        <tr>
                                            <td><%= new Date(p.date).toLocaleDateString() %></td>
                                            <td><strong><%= p.vendorName %></strong></td>
                                            <td><%= p.service %></td>
                                            <td><strong><%= formatINR(p.amount) %></strong></td>
                                            <td><span class="label label-success"><%= p.status.toUpperCase() %></span></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center">No payment transactions recorded yet.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Add AMC Vendor (Role Restricted) -->
        <div class="col-md-4">
            <% if (user.role === 'society_admin' || user.role === 'committee_member') { %>
                <div class="panel panel-default" style="border-top: 3px solid #ff9800 !important;">
                    <div class="panel-heading"><h4><i class="fas fa-file-contract"></i> Register AMC Contract</h4></div>
                    <div class="panel-body">
                        <form action="/vendors/add" method="POST">
                            <div class="form-group">
                                <label>Vendor Company Name:</label>
                                <input type="text" name="name" class="form-control" placeholder="e.g. Otis Elevators" required>
                            </div>
                            <div class="form-group">
                                <label>Service Type:</label>
                                <input type="text" name="serviceType" class="form-control" placeholder="e.g. Lift AMC, Water Tank Cleaning" required>
                            </div>
                            <div class="form-group">
                                <label>Contact Person Name:</label>
                                <input type="text" name="contactPerson" class="form-control" placeholder="e.g. John Doe" required>
                            </div>
                            <div class="form-group">
                                <label>Phone Number:</label>
                                <input type="text" name="phoneNumber" class="form-control" placeholder="Mobile Number" required>
                            </div>
                            <div class="row">
                                <div class="col-xs-6">
                                    <div class="form-group">
                                        <label>AMC Start Date:</label>
                                        <input type="date" name="amcStartDate" class="form-control" required>
                                    </div>
                                </div>
                                <div class="col-xs-6">
                                    <div class="form-group">
                                        <label>AMC Expiry Date:</label>
                                        <input type="date" name="amcEndDate" class="form-control" required>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Contract Value (₹):</label>
                                <input type="number" name="contractValue" class="form-control" placeholder="Annual Payment Amount" required>
                            </div>
                            <button type="submit" class="btn btn-warning btn-block"><i class="fas fa-plus-circle"></i> Create AMC Contract</button>
                        </form>
                    </div>
                </div>
            <% } else { %>
                <!-- Helpful info widget for committee/members -->
                <div class="panel panel-default">
                    <div class="panel-heading"><h4><i class="fas fa-info-circle"></i> Vendor Operations</h4></div>
                    <div class="panel-body" style="font-size: 13px; line-height: 1.5; color: var(--text-secondary);">
                        - Annual Maintenance Contracts (AMC) ensure critical facilities like water pumps, elevators, generator backups, and gym gear operate flawlessly.<br>
                        - Audit ratings help committee make contract renewal decisions.<br>
                        - For billing inquiries or payment logs, email society administration.
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
